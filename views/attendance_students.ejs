<%- include('partials/header') %>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="row mb-4">
    <div class="col-md-12">
        <!-- Premium Header Card -->
        <div class="card shadow-sm border-0 rounded-4 p-4 text-white" style="background: linear-gradient(135deg, #0d9488 0%, #115e59 100%);">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h1 class="fw-bold mb-1">
                        <i class="bi bi-person-check-fill me-2"></i>
                        <%= __('Class_Attendance_Title') %>: <%= __(classInfo.name_ar) %>
                    </h1>
                    <p class="text-teal-100 mb-0">
                        <% if (session.role === 'عريف') { %>
                            <%= __('CR_Marking_Instructions') || 'طلباء کی حاضری لگائیں اور محفوظ کریں' %>
                        <% } else { %>
                            <%= __('Admin_View_Only') || 'حاضری کا ریکارڈ (صرف دیکھنے کی اجازت)' %>
                        <% } %>
                    </p>
                </div>
                <% if (session.role === 'عريف') { %>
                <div class="d-flex align-items-center gap-2 bg-white bg-opacity-10 px-3 py-1 rounded-pill" style="border: 1px solid rgba(255,255,255,0.2);">
                    <label class="small text-white-50 mb-0 text-nowrap"><i class="bi bi-calendar-event me-1"></i><%= __('Jump_To_Date') %></label>
                    <input type="date" class="form-control form-control-sm bg-transparent border-0 text-white fw-bold p-0" 
                        value="<%= date %>" 
                        style="width: 130px; cursor: pointer; color-scheme: dark;" 
                        id="datePicker">
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<% if (session.role === 'عريف') { %>
<!-- Areef View: Student Attendance Marking List -->
<div class="row mb-5">
    <div class="col-md-12">
        <div class="card shadow-sm border-0 rounded-4 p-4">
            <h4 class="fw-bold text-dark mb-4"><i class="bi bi-people me-2"></i><%= __('Student_List') || 'طلباء کی فہرست' %></h4>
            
            <div class="list-group list-group-flush">
                <% students.forEach(student => { %>
                    <div class="list-group-item d-flex justify-content-between align-items-center py-3 student-item" data-id="<%= student.id %>" style="border-bottom: 1px solid #f1f5f9;">
                        <span class="fw-bold text-dark"><%= student.name %></span>
                        <div class="btn-group" role="group">
                            <button type="button" class="btn btn-outline-success btn-sm px-3 status-btn <%= student.status === 'present' ? 'active' : '' %>" data-status="present">ح</button>
                            <button type="button" class="btn btn-outline-danger btn-sm px-3 status-btn <%= student.status === 'absent' ? 'active' : '' %>" data-status="absent">غ</button>
                            <button type="button" class="btn btn-outline-warning btn-sm px-3 status-btn <%= student.status === 'leave' ? 'active' : '' %>" data-status="leave">ر</button>
                            <button type="button" class="btn btn-outline-info btn-sm px-3 status-btn <%= student.status === 'online' ? 'active' : '' %>" data-status="online">ن</button>
                        </div>
                    </div>
                <% }) %>
            </div>

            <button id="saveBtn" class="btn btn-teal rounded-pill w-100 py-2 mt-4 fw-bold"><i class="bi bi-cloud-arrow-up-fill me-1"></i><%= __('Save_Attendance_Btn') %></button>
        </div>
    </div>
</div>
<% } %>

<!-- Weekly Attendance Log (Shown to both, but is the ONLY focus for Mudeer/Nazim) -->
<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="card-header bg-white p-4 border-0">
                <h4 class="fw-bold text-teal mb-1"><i class="bi bi-clock-history me-2"></i><%= __('Weekly_Attendance_Log') || 'ہفتہ وار حاضری کا ریکارڈ (آخری 7 دن)' %></h4>
                <small class="text-muted"><%= __('Weekly_Attendance_Log_Desc') || 'کلاس کی روزانہ حاضری کے اعداد و شمار کا جائزہ' %></small>
            </div>
            
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-end mb-0">
                        <thead class="table-light">
                            <tr class="border-bottom" style="border-bottom: 2px solid #e2e8f0 !important;">
                                <th class="p-4 fw-bold text-dark"><%= __('Date_Col') %></th>
                                <th class="p-4 text-center text-success">ح (حاضر)</th>
                                <th class="p-4 text-center text-danger">غ (غیر حاضر)</th>
                                <th class="p-4 text-center text-warning">ر (رخصت)</th>
                                <th class="p-4 text-center text-info">ن (آن لائن)</th>
                                <% if (session.role === 'مدير' || session.role === 'ناظم') { %>
                                <th class="p-4 text-center"><%= __('Action') %></th>
                                <% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (history.length === 0) { %>
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
                                        <p class="mt-3 fw-bold"><%= __('No_Attendance_Records') || 'کوئی حاضری ریکارڈ نہیں ملا' %></p>
                                    </td>
                                </tr>
                            <% } else { %>
                                <% history.forEach(day => { %>
                                    <tr class="border-bottom">
                                        <td class="p-4 fw-bold text-dark"><%= day.date_str %></td>
                                        <td class="p-4 text-center fw-bold text-success"><%= day.present %></td>
                                        <td class="p-4 text-center fw-bold text-danger"><%= day.absent %></td>
                                        <td class="p-4 text-center fw-bold text-warning"><%= day.leave_count %></td>
                                        <td class="p-4 text-center fw-bold text-info"><%= day.online %></td>
                                        <% if (session.role === 'مدير' || session.role === 'ناظم') { %>
                                        <td class="p-4 text-center">
                                            <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3" onclick="showConfirm('<%= __('Confirm_Delete_Attendance_Day') %>', () => window.location.href='/attendance/delete-day/<%= classInfo.id %>/<%= day.date_str %>')">
                                                <i class="bi bi-trash3 me-1"></i><%= __('Delete') %>
                                            </button>
                                        </td>
                                        <% } %>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    <% if (session.role === 'عريف') { %>
    // Toggle active status for buttons
    document.querySelectorAll('.status-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const parent = this.parentElement;
            parent.querySelectorAll('.status-btn').forEach(b => {
                b.classList.remove('active');
                b.classList.remove('btn-success', 'btn-danger', 'btn-warning', 'btn-info');
            });
            this.classList.add('active');
            
            // Re-apply active color
            const status = this.getAttribute('data-status');
            if (status === 'present') this.classList.add('btn-success');
            else if (status === 'absent') this.classList.add('btn-danger');
            else if (status === 'leave') this.classList.add('btn-warning');
            else if (status === 'online') this.classList.add('btn-info');
        });
        
        // Initial setup for existing status colors
        if (btn.classList.contains('active')) {
            const status = btn.getAttribute('data-status');
            if (status === 'present') btn.classList.add('btn-success');
            else if (status === 'absent') btn.classList.add('btn-danger');
            else if (status === 'leave') btn.classList.add('btn-warning');
            else if (status === 'online') btn.classList.add('btn-info');
        }
    });

    document.getElementById('saveBtn').addEventListener('click', async function() {
        const date = document.getElementById('datePicker').value;
        const attendance = {};
        document.querySelectorAll('.student-item').forEach(item => {
            const id = item.getAttribute('data-id');
            const activeBtn = item.querySelector('.status-btn.active');
            const status = activeBtn ? activeBtn.getAttribute('data-status') : 'present';
            attendance[id] = status;
        });

        const classId = '<%= classInfo.id %>';
        
        const btn = this;
        const origText = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
        btn.disabled = true;

        try {
            const res = await fetch('/attendance/students/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ date, attendance, classId })
            });

            if (res.ok) {
                showToast('<%= __('Saved_Successfully') %>', 'success');
            } else {
                showToast('<%= __('Error_Saving') %>', 'error');
            }
        } catch (err) {
            console.error(err);
            showToast('<%= __('Error_Saving') %>', 'error');
        } finally {
            btn.innerHTML = origText;
            btn.disabled = false;
        }
    });

    document.getElementById('datePicker').addEventListener('change', function() {
        window.location.href = `?date=${this.value}`;
    });
    <% } %>
</script>

<style>
    .btn-teal {
        background-color: #0d9488 !important;
        border-color: #0d9488 !important;
        color: white !important;
    }
    .btn-teal:hover {
        background-color: #0f766e !important;
        border-color: #0f766e !important;
    }
    .text-teal {
        color: #0d9488 !important;
    }
</style>

<%- include('partials/footer') %>
