<!DOCTYPE html>
<html lang="<%= locals.lang || 'ur' %>" dir="<%= ['ar', 'ur'].includes(locals.lang || 'ur') ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('College_Name') %> - <%= __(classInfo.name_ar) %></title>
    <link rel="icon" href="/logo.jpg">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .status-btn.active[data-status="present"] { background: var(--success); color: white; border-color: var(--success); }
        .status-btn.active[data-status="absent"] { background: var(--danger); color: white; border-color: var(--danger); }
        .status-btn.active[data-status="leave"] { background: var(--warning); color: white; border-color: var(--warning); }
        .status-btn.active[data-status="online"] { background: #3498db; color: white; border-color: #3498db; }
    </style>
</head>
<body>
    <nav>
        <div style="display: flex; align-items: center; gap: 10px;">
            <img src="/logo.jpg" alt="Logo" style="height: 40px; border-radius: 5px;">
            <div class="logo"><%= __('College_Name') %></div>
        </div>
        <a href="/" class="btn btn-primary"><%= __('Main_Page') %></a>
    </nav>

    <div class="container">
        <header style="margin-bottom: 20px;">
            <h1><%= __('Class_Attendance_Title') %> <%= __(classInfo.name_ar) %></h1>
            <input type="date" id="datePicker" value="<%= date %>" class="btn" style="background: white; border: 1px solid #ddd;">
        </header>
 
        <div class="card">
            <ul class="attendance-list">
                <% students.forEach(student => { %>
                    <li class="student-item" data-id="<%= student.id %>">
                        <span><%= student.name %></span>
                        <div class="status-toggle">
                            <div class="status-btn <%= student.status === 'present' ? 'active' : '' %>" data-status="present" title="<%= __('Status_Present') %>">ح</div>
                            <div class="status-btn <%= student.status === 'absent' ? 'active' : '' %>" data-status="absent" title="<%= __('Status_Absent') %>">غ</div>
                            <div class="status-btn <%= student.status === 'leave' ? 'active' : '' %>" data-status="leave" title="<%= __('Status_Leave') %>">ر</div>
                            <div class="status-btn <%= student.status === 'online' ? 'active' : '' %>" data-status="online" title="<%= __('Status_Online') %>">ن</div>
                        </div>
                    </li>
                <% }) %>
            </ul>

            <div style="margin-top: 30px; border-top: 2px solid #eee; padding-top: 20px; overflow-x: auto;">
                <h3 style="margin-bottom: 15px;"><%= __('Weekly_Attendance_Log') %></h3>
                <table style="width: 100%; min-width: 300px; border-collapse: collapse; font-size: 0.9em;">
                    <thead>
                        <tr style="background: #f4f4f4;">
                            <th style="padding: 10px; text-align: inherit;"><%= __('Date_Col') %></th>
                            <th style="padding: 10px; color: var(--success);">ح</th>
                            <th style="padding: 10px; color: var(--danger);">غ</th>
                            <th style="padding: 10px; color: var(--warning);">ر</th>
                            <th style="padding: 10px; color: #3498db;">ن</th>
                            <th style="padding: 10px;"><%= __('Action') %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% history.forEach(day => { %>
                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding: 10px; text-align: inherit;"><%= day.date_str %></td>
                                <td style="padding: 10px; text-align: center; font-weight: bold;"><%= day.present %></td>
                                <td style="padding: 10px; text-align: center; font-weight: bold;"><%= day.absent %></td>
                                <td style="padding: 10px; text-align: center; font-weight: bold;"><%= day.leave_count %></td>
                                <td style="padding: 10px; text-align: center; font-weight: bold;"><%= day.online %></td>
                                <td style="padding: 10px; text-align: center;">
                                    <button type="button" class="btn btn-danger" style="padding: 4px 8px; font-size: 0.7em; white-space: nowrap;" onclick="showConfirm('<%= __('Confirm_Delete_Attendance_Day') %>', () => window.location.href='/attendance/delete-day/<%= classInfo.id %>/<%= day.date_str %>')"><%= __('Delete') %></button>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
 
            <button id="saveBtn" class="btn btn-secondary" style="width: 100%; margin-top: 20px;"><%= __('Save_Attendance_Btn') %></button>
        </div>
    </div>

    <script src="/js/main.js"></script>
    <script>
        document.querySelectorAll('.status-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const parent = this.parentElement;
                parent.querySelectorAll('.status-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
            });
        });

        document.getElementById('saveBtn').addEventListener('click', async function() {
            const date = document.getElementById('datePicker').value;
            const attendance = {};
            document.querySelectorAll('.student-item').forEach(item => {
                const id = item.getAttribute('data-id');
                const status = item.querySelector('.status-btn.active')?.getAttribute('data-status') || 'present';
                attendance[id] = status;
            });

            const classId = '<%= classInfo.id %>';
            const res = await fetch('/attendance/students/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ date, attendance, classId })
            });

            if (res.ok) {
                showToast('<%= __('Saved_Successfully') %>', 'success');
            } else {
                showToast('<%= __('Error_Saving') %>', 'error');
            }
        });

        document.getElementById('datePicker').addEventListener('change', function() {
            window.location.href = `?date=${this.value}`;
        });
    </script>
</body>
</html>
