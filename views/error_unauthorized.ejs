<%- include('partials/header') %>

<div class="row justify-content-center align-items-center my-5 py-5 text-center">
    <div class="col-md-6">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4 shadow" style="width: 100px; height: 100px; background-color: rgba(220, 53, 69, 0.1); color: #dc3545; border: 2px solid rgba(220, 53, 69, 0.2); animation: pulse 2s infinite;">
            <i class="bi bi-shield-lock-fill" style="font-size: 3rem;"></i>
        </div>
        <h1 class="fw-bold text-dark mb-3">وصول غير مصرح به</h1>
        <p class="text-muted fs-5 mb-4 px-3">
            <%= locals.message || "عذراً، ليس لديك الصلاحية الكافية للوصول إلى هذه الصفحة أو الميزة." %>
        </p>
        <div class="d-flex justify-content-center gap-3">
            <a href="/" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm">
                <i class="bi bi-house-door me-1"></i> العودة للرئيسية
            </a>
            <button onclick="history.back()" class="btn btn-outline-secondary rounded-pill px-4 py-2">
                <i class="bi bi-arrow-right me-1"></i> رجوع للخلف
            </button>
        </div>
    </div>
</div>

<style>
@keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
}
</style>

<%- include('partials/footer') %>
