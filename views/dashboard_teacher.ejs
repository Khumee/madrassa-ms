<%- include('partials/header') %>

<div class="row mb-5">
    <div class="col-md-12">
        <h1 class="fw-bold text-primary">أهلاً، <%= teacher.name %></h1>
        <p class="text-muted"><%= today %></p>
    </div>
</div>

<div class="row">
    <!-- Today's Schedule -->
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-0 rounded-4 h-100">
            <div class="card-header bg-white p-4 border-0">
                <h4 class="fw-bold mb-0 text-primary"><i class="bi bi-calendar-check me-2"></i>حصص اليوم</h4>
            </div>
            <div class="card-body p-4 pt-0">
                <% if (periods.length > 0) { %>
                    <div class="list-group list-group-flush">
                        <% periods.forEach(p => { %>
                            <div class="list-group-item px-0 py-3 border-bottom">
                                <h6 class="fw-bold mb-1"><%= p.subject %></h6>
                                <div class="d-flex justify-content-between text-muted small">
                                    <span><%= p.class_name %></span>
                                    <span><%= p.start_time %> - <%= p.end_time %></span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-clock-history fs-1 mb-3 d-block"></i>
                        لا توجد حصص مجدولة اليوم.
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Assigned Books Progress -->
    <div class="col-md-8 mb-4">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white p-4 border-0">
                <h4 class="fw-bold mb-0 text-success"><i class="bi bi-book-half me-2"></i>تقدم الكتب المقررة</h4>
            </div>
            <div class="card-body p-4 pt-0">
                <% if (assignedBooks.length > 0) { %>
                    <div class="row g-4">
                        <% assignedBooks.forEach(b => { 
                            const total = b.end_page - b.start_page;
                            const completed = b.current_page - b.start_page;
                            const percentage = total > 0 ? Math.min(100, Math.max(0, Math.round((completed / total) * 100))) : 0;
                        %>
                            <div class="col-md-6">
                                <div class="p-4 border-0 rounded-4 bg-white shadow-sm h-100 position-relative">
                                    <h5 class="fw-bold text-dark mb-1"><%= b.book_title %></h5>
                                    <p class="text-muted small mb-3"><%= b.class_name %></p>
                                    
                                    <div class="d-flex justify-content-between align-items-end mb-2">
                                        <div>
                                            <span class="text-muted x-small d-block">المستوى الحالي</span>
                                            <span class="fw-bold text-primary fs-5">صفحة <%= b.current_page %></span>
                                        </div>
                                        <div class="text-end">
                                            <span class="text-muted small">الهدف: <%= b.end_page %></span>
                                            <span class="badge bg-success-subtle text-success ms-1"><%= percentage %>%</span>
                                        </div>
                                    </div>
                                    
                                    <div class="progress mb-4" style="height: 8px; border-radius: 4px; background-color: #f0f0f0;">
                                        <div class="progress-bar bg-success" 
                                             role="progressbar" 
                                             style="width: <%= percentage %>%"></div>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <div class="input-group shadow-sm" style="max-width: 150px;">
                                            <span class="input-group-text bg-light border-0">ص</span>
                                            <input type="number" id="page_<%= b.id %>" 
                                                   class="form-control border-0 bg-light px-3 fw-bold" 
                                                   value="<%= b.current_page %>"
                                                   min="<%= b.start_page %>"
                                                   max="<%= b.end_page %>">
                                        </div>
                                        <button class="btn btn-success btn-sm px-2 rounded-3 shadow-sm" 
                                                onclick="updateProgress(<%= b.id %>, <%= b.start_page %>, <%= b.end_page %>)"
                                                title="تحديث التقدم">
                                            <i class="bi bi-arrow-left-short fs-5"></i>
                                        </button>
                                    </div>
                                    
                                    <div class="mt-3 pt-2 border-top">
                                        <small class="text-muted" style="font-size: 0.75rem;">
                                            <i class="bi bi-clock-history me-1"></i>
                                            آخر تحديث: صفحة <%= b.current_page %>
                                        </small>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-journal-x fs-1 mb-3 d-block"></i>
                        لم يتم تعيين كتب لك في هذا الفصل الدراسي.
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
async function updateProgress(assignmentId, startPage, endPage) {
    const pageInput = document.getElementById(`page_${assignmentId}`);
    const pageNumber = parseInt(pageInput.value);

    if (isNaN(pageNumber) || pageNumber < startPage || pageNumber > endPage) {
        return showToast(`يرجى إدخال رقم صفحة بين ${startPage} و ${endPage}`, 'danger');
    }
    
    const btn = event.currentTarget;
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width: 1rem; height: 1rem;"></span>';

    try {
        const res = await fetch('/book/update-progress', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ assignmentId, pageNumber })
        });
        
        const data = await res.json();
        if (data.success) {
            location.reload();
        } else {
            showToast('فشل التحديث: ' + (data.error || 'خطأ غير معروف'), 'danger');
        }
    } catch (err) {
        console.error(err);
        showToast('حدث خطأ في الاتصال بالسيرفر', 'danger');
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
    }
}
</script>

<%- include('partials/footer') %>
