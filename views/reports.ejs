<%- include('partials/header') %>

<div class="row mb-5">
    <div class="col-md-12">
        <h1 class="fw-bold text-primary">التقارير والإحصائيات</h1>
        <p class="text-muted">متابعة إنجاز الكتب وحضور الطلاب</p>
    </div>
</div>

<!-- Teacher Summary Table -->
<div class="row mb-5">
    <div class="col-md-12">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white p-4 border-0">
                <h3 class="fw-bold mb-0 text-primary">ملخص المعلمين</h3>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-end">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4">اسم المعلم</th>
                                <th>عدد الكتب المقررة</th>
                                <th>عدد الحصص (Periods)</th>
                                <th class="px-4 text-center">الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% teachers.forEach(t => { %>
                                <tr>
                                    <td class="px-4 fw-bold"><%= t.name %></td>
                                    <td>
                                        <span class="badge bg-info-subtle text-info border rounded-pill px-3">
                                            <%= t.book_count %> كتب
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-warning-subtle text-warning border rounded-pill px-3">
                                            <%= t.period_count %> حصص
                                        </span>
                                    </td>
                                    <td class="px-4 text-center">
                                        <a href="/reports/teacher/<%= t.id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3">عرض التفاصيل</a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Teacher Progress Section -->
<div class="row mb-5">
    <div class="col-md-12">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white p-4 border-0">
                <h3 class="fw-bold mb-0 text-success">إنجاز المعلمين (الكتب)</h3>
            </div>
            <div class="card-body p-4">
                <div class="row g-4">
                    <% teacherProgress.forEach(tp => { %>
                        <div class="col-md-4">
                            <div class="p-3 border rounded-4 bg-light shadow-sm h-100">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="fw-bold mb-0"><%= tp.book_title %></h6>
                                    <span class="badge bg-success rounded-pill px-2"><%= tp.percentage %>%</span>
                                </div>
                                <p class="small text-muted mb-3">المعلم: <%= tp.teacher_name %></p>
                                <div class="progress mb-2" style="height: 10px; border-radius: 5px;">
                                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" 
                                         role="progressbar" 
                                         style="width: <%= tp.percentage %>%"></div>
                                </div>
                                <div class="d-flex justify-content-between small text-muted">
                                    <span>بداية: <%= tp.start_page %></span>
                                    <span class="fw-bold text-dark">الحالي: <%= tp.current_page %></span>
                                    <span>نهاية: <%= tp.end_page %></span>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filters Section for Attendance -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">البحث عن معلم</h5>
                <div class="input-group">
                    <select id="teacherSelect" class="form-select">
                        <option value="">اختر المعلم...</option>
                        <% teachers.forEach(t => { %>
                            <option value="<%= t.id %>"><%= t.name %></option>
                        <% }) %>
                    </select>
                    <button class="btn btn-primary" onclick="viewTeacherReport()">عرض التقارير التفصيلية</button>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">تصفية الطلاب</h5>
                <input type="text" id="studentFilter" class="form-control" placeholder="ابحث عن طالب..." onkeyup="filterStudents()">
            </div>
        </div>
    </div>
</div>

<div id="studentReports">
    <% Object.keys(groupedReport).forEach(className => { %>
        <div class="card shadow-sm border-0 rounded-4 mb-5 student-class-card">
            <div class="card-header bg-white p-4 border-0">
                <h3 class="fw-bold mb-0 text-primary">حضور فصل: <%= className %></h3>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4">اسم الطالب</th>
                                <th>إجمالي الأيام</th>
                                <th>أيام الحضور</th>
                                <th class="px-4 text-center">النسبة المئوية</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% groupedReport[className].forEach(student => { %>
                                <tr class="student-row" data-name="<%= student.name.toLowerCase() %>">
                                    <td class="px-4"><%= student.name %></td>
                                    <td><%= student.total_days %></td>
                                    <td><%= student.present_days %></td>
                                    <td class="px-4 text-center">
                                        <div class="d-flex align-items-center justify-content-center gap-2">
                                            <div class="progress flex-grow-1" style="height: 8px; width: 100px;">
                                                <div class="progress-bar bg-<%= student.percentage >= 80 ? 'success' : 'danger' %>" 
                                                     role="progressbar" style="width: <%= student.percentage %>%"></div>
                                            </div>
                                            <span class="fw-bold"><%= student.percentage %>%</span>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    <% }) %>
</div>

<script>
function viewTeacherReport() {
    const id = document.getElementById('teacherSelect').value;
    if (id) window.location.href = `/reports/teacher/${id}`;
}

function filterStudents() {
    const filter = document.getElementById('studentFilter').value.toLowerCase();
    const rows = document.querySelectorAll('.student-row');
    const cards = document.querySelectorAll('.student-class-card');
    
    rows.forEach(row => {
        const name = row.getAttribute('data-name');
        if (name.includes(filter)) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });

    cards.forEach(card => {
        const visibleRows = card.querySelectorAll('.student-row[style=""]');
        card.style.display = visibleRows.length > 0 || filter === '' ? '' : 'none';
    });
}
</script>

<%- include('partials/footer') %>
