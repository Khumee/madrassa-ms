<%- include('partials/header') %>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h1 class="fw-bold text-primary mb-0">التقارير والإحصائيات</h1>
        <p class="text-muted"><%= __('Start_Date') %>: <span class="badge bg-light text-primary border"><%= startDate %></span> <%= __('End_Date') %>: <span class="badge bg-light text-primary border"><%= endDate %></span></p>
    </div>
</div>

<style>
    /* smooth arrow rotation */
    [aria-expanded="true"] .transition-icon {
        transform: rotate(180deg);
    }
    .transition-icon {
        transition: transform 0.3s ease;
    }
    .filter-trigger-btn:hover {
        background-color: #f8f9fa !important;
        border-color: var(--bs-primary) !important;
    }
</style>

<!-- Time-Based Filter Control Panel (Collapsed by default) -->
<div class="row mb-5">
    <div class="col-md-12">
        <!-- Gorgeous Toggle Button/Bar -->
        <button class="btn btn-white w-100 border shadow-sm rounded-4 p-3 d-flex justify-content-between align-items-center text-decoration-none filter-trigger-btn" 
                type="button" 
                data-bs-toggle="collapse" 
                data-bs-target="#filterCollapsePanel" 
                aria-expanded="false" 
                aria-controls="filterCollapsePanel"
                style="background: #ffffff; transition: all 0.3s ease;">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-primary-subtle text-primary rounded-3 p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <i class="bi bi-funnel-fill fs-5"></i>
                </div>
                <div class="text-end">
                    <span class="fw-bold text-dark d-block"><%= locals.lang === 'ur' ? 'فلٹر کے اختیارات' : 'خيارات تصفية التقارير' %></span>
                    <span class="text-muted small">
                        <%= locals.lang === 'ur' ? 'تاریخ کی حد منتخب کریں اور لاگو کریں' : 'حدد نطاق التواريخ المخصص لتحديث جميع الأقسام' %>
                    </span>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-light text-primary border rounded-pill px-3 py-2">
                    <i class="bi bi-calendar3 me-1"></i><%= startDate %> ⇄ <%= endDate %>
                </span>
                <i class="bi bi-chevron-down text-muted fs-5 transition-icon"></i>
            </div>
        </button>

        <!-- Collapsible Content -->
        <div class="collapse mt-3" id="filterCollapsePanel">
            <div class="card shadow-sm border-0 rounded-4" style="background: linear-gradient(135deg, #ffffff 0%, #fcfdfe 100%);">
                <div class="card-body p-4">
                    <form id="dateFilterForm" method="GET" action="/reports">
                        <div class="row align-items-end g-3">
                            <div class="col-md-3">
                                <label class="form-label fw-bold text-secondary small"><%= __('Start_Date') %></label>
                                <input type="date" name="startDate" id="startDateInput" class="form-control rounded-3 border-light shadow-sm" value="<%= startDate %>" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-bold text-secondary small"><%= __('End_Date') %></label>
                                <input type="date" name="endDate" id="endDateInput" class="form-control rounded-3 border-light shadow-sm" value="<%= endDate %>" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold text-secondary small d-block"><%= __('Date_Filter_Header') %></label>
                                <div class="btn-group w-100 shadow-sm rounded-3 overflow-hidden" role="group">
                                    <button type="button" class="btn btn-outline-primary py-2 border-light-subtle small" onclick="setPreset('1day')"><%= __('Preset_1Day') %></button>
                                    <button type="button" class="btn btn-outline-primary py-2 border-light-subtle small" onclick="setPreset('7day')"><%= __('Preset_7Day') %></button>
                                    <button type="button" class="btn btn-outline-primary py-2 border-light-subtle small" onclick="setPreset('1month')"><%= __('Preset_1Month') %></button>
                                    <button type="button" class="btn btn-outline-primary py-2 border-light-subtle small" onclick="setPreset('6month')"><%= __('Preset_6Month') %></button>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary w-100 py-2 rounded-3 fw-bold shadow-sm">
                                    <i class="bi bi-filter me-1"></i><%= __('Apply') %>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Student Attendance Section (Top) -->
<div class="row mb-5">
    <div class="col-md-12">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white p-4 border-0 d-flex justify-content-between align-items-center flex-wrap gap-3">
                <h3 class="fw-bold mb-0 text-primary">تقارير حضور الطلاب</h3>
                <button class="btn btn-outline-primary btn-sm rounded-pill px-3" type="button" data-bs-toggle="collapse" data-bs-target="#studentAttendanceFiltersCollapse" aria-expanded="false">
                    <i class="bi bi-funnel me-1"></i><%= locals.lang === 'ur' ? 'فلٹرز' : 'خيارات التصفية' %>
                </button>
            </div>
            <!-- Collapsible Filters with Tiles -->
            <div class="collapse border-bottom" id="studentAttendanceFiltersCollapse">
                <div class="p-4 bg-light-subtle">
                    <div class="row g-3">
                        <!-- Search Input -->
                        <div class="col-12 col-md-4">
                            <label class="form-label small fw-bold text-secondary mb-2"><%= locals.lang === 'ur' ? 'طالب تلاش کریں' : 'البحث عن طالب' %></label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-primary-subtle"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" id="studentFilter" class="form-control border-primary-subtle" placeholder="ابحث عن طالب..." onkeyup="filterStudents()">
                            </div>
                        </div>
                        <!-- Class Selector Tiles -->
                        <div class="col-12 col-md-8">
                            <label class="form-label small fw-bold text-secondary mb-2"><%= locals.lang === 'ur' ? 'کلاسز کے ٹائلز' : 'تصفية حسب الصف' %></label>
                            <div class="d-flex flex-wrap gap-2" id="classTilesContainer">
                                <button type="button" class="btn btn-sm btn-primary rounded-pill px-3 filter-tile active" data-filter="all" onclick="selectClassTile('all', this)">كل الصفوف</button>
                                <% Object.keys(groupedReport).forEach(className => { %>
                                    <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3 filter-tile" data-filter="<%= className %>" onclick="selectClassTile('<%= className %>', this)"><%= className %></button>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="accordion accordion-flush" id="attendanceAccordion">
                    <% Object.keys(groupedReport).forEach((className, index) => { 
                        const students = groupedReport[className];
                        const avg = Math.round(students.reduce((acc, s) => acc + s.percentage, 0) / students.length);
                    %>
                        <div class="accordion-item border rounded-4 mb-3 overflow-hidden student-class-card" data-class-name="<%= className %>">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed p-4 bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#collapse_<%= index %>">
                                    <div class="d-flex justify-content-between align-items-center w-100 me-3">
                                        <span class="fw-bold text-dark fs-5"><%= className %></span>
                                        <div class="d-flex gap-3 text-muted small">
                                            <span class="badge bg-white border text-primary rounded-pill px-3"><%= students.length %> طلاب</span>
                                            <span class="badge bg-white border text-success rounded-pill px-3">متوسط الحضور: <%= avg %>%</span>
                                        </div>
                                    </div>
                                </button>
                            </h2>
                            <div id="collapse_<%= index %>" class="accordion-collapse collapse" data-bs-parent="#attendanceAccordion">
                                <div class="accordion-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle mb-0 text-end">
                                            <thead class="table-light">
                                                <tr>
                                                    <th class="px-4">اسم الطالب</th>
                                                    <th>إجمالي الأيام</th>
                                                    <th>أيام الحضور</th>
                                                    <th class="px-4 text-center">النسبة المئوية</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% students.forEach(student => { %>
                                                    <tr class="student-row" data-name="<%= student.name.toLowerCase() %>">
                                                        <td class="px-4"><%= student.name %></td>
                                                        <td><%= student.total_days %></td>
                                                        <td><%= student.present_days %></td>
                                                        <td class="px-4 text-center">
                                                            <div class="d-flex align-items-center justify-content-center gap-2">
                                                                <div class="progress flex-grow-1" style="height: 8px; width: 100px;">
                                                                    <div class="progress-bar bg-<%= student.percentage >= 80 ? 'success' : 'danger' %>" 
                                                                         role="progressbar" style="width: <%= student.percentage %>%"></div>
                                                                </div>
                                                                <span class="fw-bold"><%= student.percentage %>%</span>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Teacher Attendance and Period Variance Report (New Section) -->
<div class="row mb-5">
    <div class="col-md-12">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white p-4 border-0 d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h3 class="fw-bold mb-0 text-warning"><%= __('Teacher_Period_Report_Header') %></h3>
                    <p class="text-muted mb-0 small"><%= __('Teacher_Period_Report_Sub') %></p>
                </div>
                <button class="btn btn-outline-warning btn-sm rounded-pill px-3" type="button" data-bs-toggle="collapse" data-bs-target="#teacherAttendanceFiltersCollapse" aria-expanded="false">
                    <i class="bi bi-funnel me-1"></i><%= locals.lang === 'ur' ? 'فلٹرز' : 'خيارات التصفية' %>
                </button>
            </div>
            <!-- Collapsible Filters with Teacher Tiles -->
            <div class="collapse border-bottom" id="teacherAttendanceFiltersCollapse">
                <div class="p-4 bg-light-subtle">
                    <label class="form-label small fw-bold text-secondary mb-2"><%= locals.lang === 'ur' ? 'اساتذہ کے ٹائلز' : 'تصفية حسب المعلم' %></label>
                    <div class="d-flex flex-wrap gap-2" id="teacherTilesContainer">
                        <button type="button" class="btn btn-sm btn-warning rounded-pill px-3 teacher-filter-tile active" data-filter="all" onclick="selectTeacherTile('all', this)">كل المعلمين</button>
                        <% 
                        const uniqueTeachers = [...new Set(teachersReport.map(tr => tr.name))];
                        uniqueTeachers.forEach(teacherName => { 
                        %>
                            <button type="button" class="btn btn-sm btn-outline-warning rounded-pill px-3 teacher-filter-tile" data-filter="<%= teacherName %>" onclick="selectTeacherTile('<%= teacherName %>', this)"><%= teacherName %></button>
                        <% }) %>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-end">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4"><%= __('Teacher_Name') %></th>
                                <th><%= __('Required_Periods') %></th>
                                <th><%= __('Taken_Periods') %></th>
                                <th class="px-4 text-center"><%= __('Status_Variance') %></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% teachersReport.forEach(tr => { %>
                                <tr class="teacher-attendance-row" data-teacher-name="<%= tr.name %>">
                                    <td class="px-4 fw-bold text-dark"><%= tr.name %></td>
                                    <td><span class="badge bg-light text-secondary border rounded-3 px-3 py-2"><%= tr.required %></span></td>
                                    <td><span class="badge bg-light text-primary border rounded-3 px-3 py-2"><%= tr.taken %></span></td>
                                    <td class="px-4 text-center">
                                        <% if (tr.difference === 0) { %>
                                            <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2 fw-bold">
                                                <i class="bi bi-check-circle-fill me-1"></i><%= __('Ontime') %>
                                            </span>
                                        <% } else if (tr.difference > 0) { %>
                                            <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2 fw-bold">
                                                <i class="bi bi-plus-circle-fill me-1"></i><%= __('Extra_Makeup') %> (+<%= tr.difference %>)
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-2 fw-bold">
                                                <i class="bi bi-exclamation-triangle-fill me-1"></i><%= __('Shortage') %> (<%= tr.difference %>)
                                            </span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Teacher Book Progress Section -->
<div class="row mb-5">
    <div class="col-md-12">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white p-4 border-0 d-flex justify-content-between align-items-center flex-wrap gap-3">
                <h3 class="fw-bold mb-0 text-success">تقرير إنجاز الكتب</h3>
                <button class="btn btn-outline-success btn-sm rounded-pill px-3" type="button" data-bs-toggle="collapse" data-bs-target="#bookProgressFiltersCollapse" aria-expanded="false">
                    <i class="bi bi-funnel me-1"></i><%= locals.lang === 'ur' ? 'فلٹرز' : 'خيارات التصفية' %>
                </button>
            </div>
            <!-- Collapsible Filters with Class and Teacher Tiles -->
            <div class="collapse border-bottom" id="bookProgressFiltersCollapse">
                <div class="p-4 bg-light-subtle">
                    <div class="row g-4">
                        <!-- Search Input -->
                        <div class="col-12 col-md-4">
                            <label class="form-label small fw-bold text-secondary mb-2"><%= locals.lang === 'ur' ? 'تلاش کریں' : 'البحث النصي' %></label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-success-subtle"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" id="teacherBookFilter" class="form-control border-success-subtle" placeholder="ابحث عن معلم أو كتاب..." onkeyup="filterTeacherBooks()">
                            </div>
                        </div>
                        
                        <!-- Class Selector Tiles -->
                        <div class="col-12 col-md-8">
                            <label class="form-label small fw-bold text-secondary mb-2"><%= locals.lang === 'ur' ? 'کلاسز کے ٹائلز' : 'تصفية حسب الصف' %></label>
                            <div class="d-flex flex-wrap gap-2" id="bookClassTilesContainer">
                                <button type="button" class="btn btn-sm btn-success rounded-pill px-3 book-class-tile active" onclick="selectBookClassTile('all', this)">كل الصفوف</button>
                                <% 
                                const uniqueBookClasses = [...new Set(teacherProgress.map(tp => tp.class_name).filter(Boolean))];
                                uniqueBookClasses.forEach(className => { 
                                %>
                                    <button type="button" class="btn btn-sm btn-outline-success rounded-pill px-3 book-class-tile" onclick="selectBookClassTile('<%= className %>', this)"><%= className %></button>
                                <% }) %>
                            </div>
                        </div>

                        <!-- Teacher Selector Tiles -->
                        <div class="col-12">
                            <label class="form-label small fw-bold text-secondary mb-2"><%= locals.lang === 'ur' ? 'اساتذہ کے ٹائلز' : 'تصفية حسب المعلم' %></label>
                            <div class="d-flex flex-wrap gap-2" id="bookTeacherTilesContainer">
                                <button type="button" class="btn btn-sm btn-success rounded-pill px-3 book-teacher-tile active" onclick="selectBookTeacherTile('all', this)">كل المعلمين</button>
                                <% 
                                const uniqueBookTeachers = [...new Set(teacherProgress.map(tp => tp.teacher_name).filter(Boolean))];
                                uniqueBookTeachers.forEach(teacherName => { 
                                %>
                                    <button type="button" class="btn btn-sm btn-outline-success rounded-pill px-3 book-teacher-tile" onclick="selectBookTeacherTile('<%= teacherName %>', this)"><%= teacherName %></button>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-end">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4">المعلم</th>
                                <th>الكتاب</th>
                                <th>الصف</th>
                                <th>التقدم</th>
                                <th class="px-4 text-center">الإجراء</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% teacherProgress.forEach(tp => { %>
                                <tr class="teacher-book-row" data-teacher="<%= tp.teacher_name.toLowerCase() %>" data-book="<%= tp.book_title.toLowerCase() %>" data-class="<%= tp.class_name || '' %>">
                                    <td class="px-4 fw-bold">
                                        <a href="/reports/teacher/<%= tp.teacher_id %>" class="text-decoration-none text-success hover-underline">
                                            <i class="bi bi-person-fill me-1"></i><%= tp.teacher_name %>
                                        </a>
                                    </td>
                                    <td><%= tp.book_title %></td>
                                    <td><span class="badge bg-primary-subtle text-primary rounded-pill"><%= tp.class_name %></span></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <div class="progress flex-grow-1" style="height: 8px; width: 100px;">
                                                <div class="progress-bar bg-success" role="progressbar" style="width: <%= tp.percentage %>%"></div>
                                            </div>
                                            <span class="small text-muted">ص <%= tp.current_page %> (<%= tp.percentage %>%)</span>
                                        </div>
                                        <% if (tp.last_updated_at) { %>
                                            <small class="text-muted d-block" style="font-size: 0.72rem;">
                                                <i class="bi bi-clock-history me-1"></i><%= __('Last_Updated') %>: <%= tp.lastUpdatedStr %>
                                            </small>
                                        <% } else { %>
                                            <small class="text-muted d-block" style="font-size: 0.72rem;">
                                                لا توجد تحديثات بعد
                                            </small>
                                        <% } %>
                                    </td>
                                    <td class="px-4 text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a href="/reports/teacher/<%= tp.teacher_id %>" class="btn btn-sm btn-outline-success rounded-pill px-3">
                                                <i class="bi bi-graph-up me-1"></i>الرسم البياني
                                            </a>
                                            <button class="btn btn-sm btn-success rounded-pill px-3" 
                                                    onclick="openProgressModal(<%= JSON.stringify(tp) %>)">
                                                تحديث
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update Progress Modal -->
<div class="modal fade" id="updateProgressModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header bg-success text-white rounded-top-4">
                <h5 class="modal-title">تحديث تقدم الكتاب</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="updateProgressForm">
                    <input type="hidden" id="progAssignmentId">
                    <div class="mb-3 text-center">
                        <h6 class="fw-bold text-dark mb-1" id="progBookTitle"></h6>
                        <p class="text-muted small" id="progTeacherName"></p>
                    </div>
                    <div class="mb-4 text-center">
                        <label class="form-label fw-bold d-block mb-3">رقم الصفحة الحالية</label>
                        <div class="d-flex align-items-center justify-content-center gap-3">
                            <input type="number" id="progPageNumber" 
                                   class="form-control border-0 shadow-sm rounded-3 text-center fw-bold text-success bg-light" 
                                   style="height: 60px; font-size: 1.5rem; width: 150px;"
                                   required>
                        </div>
                        <small class="text-muted mt-2 d-block" id="progRangeText"></small>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-success rounded-pill py-2 fw-bold">حفظ التحديث</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function setPreset(preset) {
    const today = new Date();
    const formatDate = (date) => {
        const y = date.getFullYear();
        const m = String(date.getMonth() + 1).padStart(2, '0');
        const d = String(date.getDate()).padStart(2, '0');
        return `${y}-${m}-${d}`;
    };

    let start, end = today;
    
    if (preset === '1day') {
        start = today;
    } else if (preset === '7day') {
        start = new Date();
        start.setDate(today.getDate() - 6);
    } else if (preset === '1month') {
        start = new Date(today.getFullYear(), today.getMonth(), 1);
    } else if (preset === '6month') {
        start = new Date();
        start.setMonth(today.getMonth() - 6);
    }
    
    document.getElementById('startDateInput').value = formatDate(start);
    document.getElementById('endDateInput').value = formatDate(end);
    document.getElementById('dateFilterForm').submit();
}

function viewTeacherReport() {
    const id = document.getElementById('teacherSelect').value;
    if (id) window.location.href = `/reports/teacher/${id}`;
}

// ==========================================
// Section 1: Student Attendance Filter Logic
// ==========================================
let activeClassFilter = 'all';

function selectClassTile(className, btn) {
    const container = document.getElementById('classTilesContainer');
    container.querySelectorAll('.filter-tile').forEach(b => {
        b.classList.remove('btn-primary', 'active');
        b.classList.add('btn-outline-primary');
    });
    btn.classList.remove('btn-outline-primary');
    btn.classList.add('btn-primary', 'active');
    
    activeClassFilter = className;
    applyCombinedStudentFilter();
}

function filterStudents() {
    applyCombinedStudentFilter();
}

function applyCombinedStudentFilter() {
    const searchText = document.getElementById('studentFilter').value.toLowerCase();
    const cards = document.querySelectorAll('.student-class-card');
    
    cards.forEach(card => {
        const className = card.getAttribute('data-class-name');
        const rows = card.querySelectorAll('.student-row');
        let visibleRows = 0;
        
        rows.forEach(row => {
            const name = row.getAttribute('data-name');
            const matchesText = name.includes(searchText);
            
            if (matchesText) {
                row.style.display = '';
                visibleRows++;
            } else {
                row.style.display = 'none';
            }
        });
        
        const matchesClass = activeClassFilter === 'all' || className === activeClassFilter;
        
        if (visibleRows > 0 && matchesClass) {
            card.style.display = '';
        } else {
            card.style.display = 'none';
        }
    });
}

// ==========================================
// Section 2: Teacher Attendance Filter Logic
// ==========================================
function selectTeacherTile(teacherName, btn) {
    const container = document.getElementById('teacherTilesContainer');
    container.querySelectorAll('.teacher-filter-tile').forEach(b => {
        b.classList.remove('btn-warning', 'active');
        b.classList.add('btn-outline-warning');
    });
    btn.classList.remove('btn-outline-warning');
    btn.classList.add('btn-warning', 'active');
    
    const rows = document.querySelectorAll('.teacher-attendance-row');
    rows.forEach(row => {
        const rowTeacher = row.getAttribute('data-teacher-name');
        if (teacherName === 'all' || rowTeacher === teacherName) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
}

// ==========================================
// Section 3: Teacher Book Progress Filter Logic
// ==========================================
let activeBookClassFilter = 'all';
let activeBookTeacherFilter = 'all';

function selectBookClassTile(className, btn) {
    const container = document.getElementById('bookClassTilesContainer');
    container.querySelectorAll('.book-class-tile').forEach(b => {
        b.classList.remove('btn-success', 'active');
        b.classList.add('btn-outline-success');
    });
    btn.classList.remove('btn-outline-success');
    btn.classList.add('btn-success', 'active');
    
    activeBookClassFilter = className;
    applyCombinedBookFilter();
}

function selectBookTeacherTile(teacherName, btn) {
    const container = document.getElementById('bookTeacherTilesContainer');
    container.querySelectorAll('.book-teacher-tile').forEach(b => {
        b.classList.remove('btn-success', 'active');
        b.classList.add('btn-outline-success');
    });
    btn.classList.remove('btn-outline-success');
    btn.classList.add('btn-success', 'active');
    
    activeBookTeacherFilter = teacherName;
    applyCombinedBookFilter();
}

function filterTeacherBooks() {
    applyCombinedBookFilter();
}

function applyCombinedBookFilter() {
    const filterText = document.getElementById('teacherBookFilter').value.toLowerCase();
    const rows = document.querySelectorAll('.teacher-book-row');
    
    rows.forEach(row => {
        const teacher = row.getAttribute('data-teacher');
        const book = row.getAttribute('data-book');
        const className = row.getAttribute('data-class');
        
        const matchesText = teacher.includes(filterText) || book.includes(filterText);
        const matchesClass = activeBookClassFilter === 'all' || className === activeBookClassFilter;
        const matchesTeacher = activeBookTeacherFilter === 'all' || teacher === activeBookTeacherFilter.toLowerCase();
        
        if (matchesText && matchesClass && matchesTeacher) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
}

let progressModal;
document.addEventListener('DOMContentLoaded', () => {
    progressModal = new bootstrap.Modal(document.getElementById('updateProgressModal'));
});

function openProgressModal(tp) {
    document.getElementById('progAssignmentId').value = tp.assignment_id;
    document.getElementById('progBookTitle').innerText = tp.book_title;
    document.getElementById('progTeacherName').innerText = `المعلم: ${tp.teacher_name}`;
    document.getElementById('progPageNumber').value = tp.current_page;
    document.getElementById('progPageNumber').min = tp.start_page;
    document.getElementById('progPageNumber').max = tp.end_page;
    document.getElementById('progRangeText').innerText = `النطاق المسموح: من ${tp.start_page} إلى ${tp.end_page}`;
    progressModal.show();
}

document.getElementById('updateProgressForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const assignmentId = document.getElementById('progAssignmentId').value;
    const pageNumber = document.getElementById('progPageNumber').value;
    
    const res = await fetch('/book/update-progress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ assignmentId, pageNumber })
    });
    const data = await res.json();
    if (data.success) {
        location.reload();
    } else {
        alert('خطأ: ' + (data.error || 'فشل التحديث'));
    }
});
</script>

