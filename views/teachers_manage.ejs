<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إدارة المعلمين</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <div style="display: flex; align-items: center; gap: 10px;">
            <img src="/logo.jpg" alt="Logo" style="height: 40px; border-radius: 5px;">
            <div class="logo">كليّة العلوم الإسلامية</div>
        </div>
        <a href="/" class="btn btn-primary">الرئيسية</a>
    </nav>

    <div class="container">
        <div class="card" style="max-width: 1000px;">
            <h1>إدارة المعلمين</h1>
            <p>تعديل بيانات المعلمين</p>

            <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
                <thead>
                    <tr style="background: var(--primary); color: white;">
                        <th style="padding: 10px;">الاسم</th>
                        <th style="padding: 10px;">المادة / التخصص</th>
                        <th style="padding: 10px;">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    <% teachers.forEach(teacher => { %>
                        <tr style="border-bottom: 1px solid #ddd;">
                            <td colspan="3" style="padding: 0;">
                                <form action="/teachers/edit/<%= teacher.id %>" method="POST" style="display: flex; width: 100%; align-items: center; padding: 10px; gap: 10px;">
                                    <div style="flex: 2;">
                                        <input type="text" name="name" value="<%= teacher.name %>" class="btn" style="width: 100%; background: #f9f9f9; text-align: center; border: 1px solid #eee;" required>
                                    </div>
                                    <div style="flex: 2;">
                                        <input type="text" name="subject" value="<%= teacher.subject %>" class="btn" style="width: 100%; background: #f9f9f9; text-align: center; border: 1px solid #eee;">
                                    </div>
                                    <div>
                                        <button type="submit" class="btn btn-secondary">تعديل</button>
                                        <a href="/teachers/delete/<%= teacher.id %>" class="btn btn-danger" onclick="return confirm('هل أنت متأكد؟')" style="padding: 10px 15px;">حذف</a>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
