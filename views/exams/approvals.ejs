<%- include('../partials/header', { title: 'Approvals' }) %>
<div class="container mt-4">
    <h2><%= __('Paper_Approvals') %></h2>
    <table class="table table-bordered mt-3">
        <thead class="table-dark">
            <tr>
                <th><%= __('Exam') %></th>
                <th><%= __('Class') %></th>
                <th><%= __('Subject') %></th>
                <th><%= __('Teacher') %></th>
                <th><%= __('Status') %></th>
                <th><%= __('Actions') %></th>
            </tr>
        </thead>
        <tbody>
            <% papers.forEach(p => { %>
                <tr>
                    <td><%= p.exam_name %></td>
                    <td><%= p.class_name %></td>
                    <td><%= p.subject %></td>
                    <td><%= p.teacher_name %></td>
                    <td><%= p.status %></td>
                    <td>
                        <a href="/papers/<%= p.id %>/view" class="btn btn-sm btn-info text-white"><%= __('View_Paper') || 'View Paper' %></a>
                        <form action="/papers/<%= p.id %>/approve" method="POST" style="display:inline;">
                            <input type="hidden" name="status" value="approved">
                            <button type="submit" class="btn btn-sm btn-success"><%= __('Approve') %></button>
                        </form>
                        <form action="/papers/<%= p.id %>/approve" method="POST" style="display:inline;">
                            <input type="hidden" name="status" value="rejected">
                            <button type="submit" class="btn btn-sm btn-danger"><%= __('Reject') %></button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</div>
<%- include('../partials/footer') %>
