<%- include('../partials/header', { title: 'Report Card' }) %>
<div class="container mt-4">
    <div class="card shadow-lg p-4" style="max-width: 600px; margin: auto;">
        <div class="text-center mb-4">
            <h2><%= __('Student_Report_Card') %></h2>
            <h4><%= student.name %> (<%= __('Roll_Number') %>: <%= student.roll_number %>)</h4>
        </div>
        
        <table class="table table-bordered text-center">
            <thead class="table-dark">
                <tr>
                    <th><%= __('Subject') %></th>
                    <th><%= __('Max_Marks') %></th>
                    <th><%= __('Obtained_Marks') %></th>
                </tr>
            </thead>
            <tbody>
                <% results.forEach(r => { %>
                    <tr>
                        <td><%= r.subject %></td>
                        <td><%= r.max_marks %></td>
                        <td><%= r.obtained_marks %></td>
                    </tr>
                <% }) %>
                <tr class="table-secondary fw-bold">
                    <td><%= __('Total') %></td>
                    <td><%= totalMax %></td>
                    <td><%= totalObtained %></td>
                </tr>
            </tbody>
        </table>
        
        <div class="alert alert-<%= gradeClass %> text-center fs-4 mt-3">
            <strong><%= __('Grade') %>:</strong> <%= grade %> <br>
            <small>(<%= percentage %>% <%= __('Percentage') %>)</small>
        </div>
        
        <div class="text-center mt-3">
            <button onclick="window.print()" class="btn btn-dark"><%= __('Print_Report_Card') %></button>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>
