<%- include('../partials/header', { title: __('Assign_Papers') }) %>

<div class="container mt-4">
    <div class="mb-4">
        <a href="/exams" class="btn btn-outline-secondary">&larr; <%= __('Back_to_Exams') %></a>
        <h2 class="mt-3"><%= __('Assign_Papers') %>: <%= exam.name %></h2>
    </div>

    <div class="row">
        <!-- Assignment Form -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white"><%= __('Assign_New_Paper') %></div>
                <div class="card-body">
                    <form action="/exams/<%= exam.id %>/assign" method="POST">
                        <div class="mb-3">
                            <label class="form-label"><%= __('Class') %></label>
                            <select name="class_id" class="form-select" required>
                                <option value=""><%= __('Select_Class') %></option>
                                <% classes.forEach(c => { %>
                                    <option value="<%= c.id %>"><%= c.name_ar %> - <%= c.name_en %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label"><%= __('Subject') %></label>
                            <select name="subject" id="subjectSelect" class="form-select" required>
                                <option value=""><%= __('Select_Subject') || 'Select Subject' %></option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label"><%= __('Teacher') %></label>
                            <select name="teacher_id" class="form-select" required>
                                <option value=""><%= __('Select_Teacher') %></option>
                                <% teachers.forEach(t => { %>
                                    <option value="<%= t.id %>"><%= t.username %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label"><%= __('Max_Marks') %></label>
                            <input type="number" name="max_marks" class="form-control" value="100" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100"><%= __('Assign_Paper') %></button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Assigned Papers List -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white"><%= __('Assigned_Papers') %></div>
                <div class="card-body">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th><%= __('Class') %></th>
                                <th><%= __('Subject') %></th>
                                <th><%= __('Assigned_Teacher') %></th>
                                <th><%= __('Max_Marks') %></th>
                                <th><%= __('Status') %></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (assignedPapers && assignedPapers.length > 0) { %>
                                <% assignedPapers.forEach(paper => { %>
                                    <tr>
                                        <td><%= paper.class_name %></td>
                                        <td><%= paper.subject %></td>
                                        <td><%= paper.teacher_name %></td>
                                        <td><%= paper.max_marks %></td>
                                        <td><span class="badge bg-<%= paper.status === 'published' ? 'success' : (paper.status === 'completed' ? 'secondary' : 'warning') %>"><%= __(paper.status) || paper.status %></span></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="5" class="text-center"><%= __('No_papers_assigned_yet') %></td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const books = <%- JSON.stringify(books || []) %>;
        const classSelect = document.querySelector('select[name="class_id"]');
        const subjectSelect = document.getElementById('subjectSelect');

        classSelect.addEventListener('change', function() {
            const classId = this.value;
            subjectSelect.innerHTML = '<option value=""><%= __('Select_Subject') || 'Select Subject' %></option>';
            if (classId) {
                const classBooks = books.filter(b => b.class_id == classId);
                classBooks.forEach(b => {
                    const opt = document.createElement('option');
                    opt.value = b.title;
                    opt.textContent = b.title;
                    subjectSelect.appendChild(opt);
                });
            }
        });
    });
</script>
<%- include('../partials/footer') %>
