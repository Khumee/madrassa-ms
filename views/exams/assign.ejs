<%- include('../partials/header', { title: 'Assign Papers' }) %>

<div class="container mt-4">
    <div class="mb-4">
        <a href="/exams" class="btn btn-outline-secondary">&larr; Back to Exams</a>
        <h2 class="mt-3">Assign Papers: <%= exam.name %></h2>
    </div>

    <div class="row">
        <!-- Assignment Form -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">Assign New Paper</div>
                <div class="card-body">
                    <form action="/exams/<%= exam.id %>/assign" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Class</label>
                            <select name="class_id" class="form-select" required>
                                <option value="">Select Class</option>
                                <% classes.forEach(c => { %>
                                    <option value="<%= c.id %>"><%= c.name_ar %> - <%= c.name_en %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <input type="text" name="subject" class="form-control" required placeholder="e.g. Fiqh, Hadith">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Teacher</label>
                            <select name="teacher_id" class="form-select" required>
                                <option value="">Select Teacher</option>
                                <% teachers.forEach(t => { %>
                                    <option value="<%= t.id %>"><%= t.username %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Max Marks</label>
                            <input type="number" name="max_marks" class="form-control" value="100" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Assign Paper</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Assigned Papers List -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">Assigned Papers</div>
                <div class="card-body">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Class</th>
                                <th>Subject</th>
                                <th>Assigned Teacher</th>
                                <th>Max Marks</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (assignedPapers && assignedPapers.length > 0) { %>
                                <% assignedPapers.forEach(paper => { %>
                                    <tr>
                                        <td><%= paper.class_name %></td>
                                        <td><%= paper.subject %></td>
                                        <td><%= paper.teacher_name %></td>
                                        <td><%= paper.max_marks %></td>
                                        <td><span class="badge bg-secondary"><%= paper.status %></span></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="5" class="text-center">No papers assigned yet.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
