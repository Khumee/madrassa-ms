<%- include('../partials/header', { title: __('View_Paper') || 'View Paper' }) %>
<div class="container mt-4">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><%= __('Exam_Details') %></h5>
        </div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-3"><strong><%= __('Exam') %>:</strong> <br> <%= paper.exam_name %></div>
                <div class="col-md-3"><strong><%= __('Class') %>:</strong> <br> <%= paper.class_name %></div>
                <div class="col-md-3"><strong><%= __('Subject') %>:</strong> <br> <%= paper.subject %></div>
                <div class="col-md-3"><strong><%= __('Teacher') %>:</strong> <br> <%= paper.teacher_name %></div>
            </div>
            <div class="text-center mt-3">
                <span class="badge bg-<%= paper.status === 'approved' ? 'success' : (paper.status === 'rejected' ? 'danger' : 'warning') %> fs-6">
                    <%= paper.status %>
                </span>
            </div>
        </div>
    </div>

    <h4 class="mb-3"><%= __('Questions') %></h4>
    <div class="list-group mb-4">
        <% if (questions && questions.length > 0) { %>
            <% questions.forEach((q, index) => { %>
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <strong><%= __('Question_Text') %> <%= index + 1 %>:</strong> <%= q.question_text %>
                        <br>
                        <small class="text-muted"><%= __('Section') %>: <%= q.section %></small>
                    </div>
                    <span class="badge bg-primary rounded-pill"><%= q.marks %> <%= __('Marks') %></span>
                </div>
            <% }) %>
        <% } else { %>
            <div class="alert alert-warning"><%= __('No_questions_added_yet') %></div>
        <% } %>
    </div>

    <div class="d-flex gap-3 justify-content-center">
        <% if (paper.status === 'submitted') { %>
            <form action="/papers/<%= paper.id %>/approve" method="POST">
                <input type="hidden" name="status" value="approved">
                <button type="submit" class="btn btn-lg btn-success px-5"><%= __('Approve') %></button>
            </form>
            <form action="/papers/<%= paper.id %>/approve" method="POST">
                <input type="hidden" name="status" value="rejected">
                <button type="submit" class="btn btn-lg btn-danger px-5"><%= __('Reject') %></button>
            </form>
        <% } %>
        <a href="/papers/approvals" class="btn btn-lg btn-secondary px-5"><%= __('Cancel') %></a>
    </div>
</div>
<%- include('../partials/footer') %>
