<%- include('../partials/header', { title: 'Exam Results' }) %>
<div class="container mt-4">
    <h2>Exam Results</h2>
    <p>Generate individual report cards for students.</p>
    
    <table class="table table-bordered mt-3">
        <thead class="table-dark">
            <tr>
                <th>Student ID</th>
                <th>Name</th>
                <th>Class</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% if (typeof students !== 'undefined') { %>
                <% students.forEach(s => { %>
                    <tr>
                        <td><%= s.id %></td>
                        <td><%= s.name %></td>
                        <td><%= s.class_name %></td>
                        <td>
                            <a href="/exams/<%= exam_id %>/student/<%= s.id %>/report-card" class="btn btn-sm btn-primary">View Report Card</a>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr><td colspan="4" class="text-center">Please enter an exam ID to view students.</td></tr>
            <% } %>
        </tbody>
    </table>
</div>
<%- include('../partials/footer') %>
