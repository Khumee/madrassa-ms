<%- include('partials/header') %>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-bold mb-0">أهلاً، <%= student.name %></h2>
                            <p class="text-muted">مرحباً بك في لوحة تحكم الطالب</p>
                        </div>
                        <a href="/profile/change-password" class="btn btn-outline-primary rounded-pill">تغيير كلمة المرور</a>
                    </div>

                    <div class="row g-4 mb-4">
                        <!-- Today's Schedule -->
                        <div class="col-md-6">
                            <div class="card shadow-sm border-0 rounded-4 h-100 bg-light">
                                <div class="card-header bg-white p-3 border-0 d-flex justify-content-between align-items-center">
                                    <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-calendar-check me-2"></i>جدول اليوم</h5>
                                    <a href="/periods/full" class="btn btn-sm btn-outline-primary rounded-pill">الجدول الكامل</a>
                                </div>
                                <div class="card-body p-3">
                                    <% if (periods.length > 0) { %>
                                        <div class="list-group list-group-flush">
                                            <% periods.forEach(p => { %>
                                                <div class="list-group-item px-0 py-2 border-bottom bg-transparent">
                                                    <div class="d-flex justify-content-between">
                                                        <h6 class="fw-bold mb-1"><%= p.subject %></h6>
                                                        <span class="badge bg-primary-subtle text-primary">الحصة <%= p.period_number %></span>
                                                    </div>
                                                    <div class="d-flex justify-content-between text-muted small">
                                                        <span><i class="bi bi-person me-1"></i><%= p.teacher_name %></span>
                                                        <span><i class="bi bi-clock me-1"></i><%= p.start_time %> - <%= p.end_time %></span>
                                                    </div>
                                                </div>
                                            <% }) %>
                                        </div>
                                    <% } else { %>
                                        <div class="text-center py-4 text-muted">
                                            <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>
                                            لا توجد حصص اليوم
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <!-- Book Progress -->
                        <div class="col-md-6">
                            <div class="card shadow-sm border-0 rounded-4 h-100 bg-light">
                                <div class="card-header bg-white p-3 border-0">
                                    <h5 class="fw-bold mb-0 text-success"><i class="bi bi-book-half me-2"></i>تقدم الكتب</h5>
                                </div>
                                <div class="card-body p-3">
                                    <% if (books.length > 0) { %>
                                        <% books.forEach(b => { 
                                            const total = b.end_page - b.start_page;
                                            const completed = b.current_page - b.start_page;
                                            const percentage = total > 0 ? Math.min(100, Math.max(0, Math.round((completed / total) * 100))) : 0;
                                        %>
                                            <div class="mb-3">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <h6 class="fw-bold mb-0 text-truncate" style="max-width: 70%;"><%= b.book_title %></h6>
                                                    <span class="text-success fw-bold small"><%= percentage %>%</span>
                                                </div>
                                                <div class="progress" style="height: 6px; border-radius: 3px;">
                                                    <div class="progress-bar bg-success" style="width: <%= percentage %>%"></div>
                                                </div>
                                                <div class="d-flex justify-content-between mt-1">
                                                    <small class="text-muted" style="font-size: 0.7rem;">أ. <%= b.teacher_name %></small>
                                                    <small class="text-primary fw-bold" style="font-size: 0.7rem;">صفحة <%= b.current_page %></small>
                                                </div>
                                            </div>
                                        <% }) %>
                                    <% } else { %>
                                        <div class="text-center py-4 text-muted">
                                            <i class="bi bi-journal-x fs-2 d-block mb-2"></i>
                                            لم يتم تعيين كتب بعد
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <h4 class="mb-3 fw-bold"><i class="bi bi-clock-history me-2"></i>سجل الحضور الأخير</h4>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>التاريخ</th>
                                    <th>الحالة</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% attendance.forEach(row => { %>
                                    <tr>
                                        <td><%= row.date.toISOString().split('T')[0] %></td>
                                        <td>
                                            <span class="badge rounded-pill bg-<%= 
                                                row.status === 'present' ? 'success' : 
                                                row.status === 'absent' ? 'danger' : 
                                                row.status === 'leave' ? 'warning' : 'info' 
                                            %>">
                                                <%= row.status === 'present' ? 'حاضر' : 
                                                    row.status === 'absent' ? 'غائب' : 
                                                    row.status === 'leave' ? 'إجازة' : 'أونلاين' %>
                                            </span>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
