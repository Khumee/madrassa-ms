<%- include('partials/header') %>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-bold mb-0">أهلاً، <%= student.name %></h2>
                            <p class="text-muted">مرحباً بك في لوحة تحكم الطالب</p>
                        </div>
                        <a href="/profile/change-password" class="btn btn-outline-primary rounded-pill">تغيير كلمة المرور</a>
                    </div>

                    <h4 class="mb-3">سجل الحضور الأخير</h4>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>التاريخ</th>
                                    <th>الحالة</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% attendance.forEach(row => { %>
                                    <tr>
                                        <td><%= row.date.toISOString().split('T')[0] %></td>
                                        <td>
                                            <span class="badge rounded-pill bg-<%= 
                                                row.status === 'present' ? 'success' : 
                                                row.status === 'absent' ? 'danger' : 
                                                row.status === 'leave' ? 'warning' : 'info' 
                                            %>">
                                                <%= row.status === 'present' ? 'حاضر' : 
                                                    row.status === 'absent' ? 'غائب' : 
                                                    row.status === 'leave' ? 'إجازة' : 'أونلاين' %>
                                            </span>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
