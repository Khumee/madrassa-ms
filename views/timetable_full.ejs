<%- include('partials/header') %>

<div class="row mb-4 align-items-center no-print">
    <div class="col-md-6">
        <h1 class="fw-bold text-primary mb-0">الجداول الدراسية لكل الفصول</h1>
        <p class="text-muted">نظرة شاملة موزعة حسب الصفوف (Mon-Sat)</p>
    </div>
    <div class="col-md-6 text-start">
        <button onclick="window.print()" class="btn btn-dark rounded-pill px-4 me-2">
            <i class="bi bi-printer me-2"></i>طباعة الجداول
        </button>
        <a href="/periods/manage" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-gear me-2"></i>الإدارة
        </a>
    </div>
</div>

<!-- Filter Chips -->
<div class="card shadow-sm border-0 rounded-4 mb-4 no-print">
    <div class="card-body p-3">
        <div class="row g-3">
            <div class="col-md-6 border-end">
                <small class="text-muted d-block mb-1 fw-bold">تصفية حسب الأستاذ:</small>
                <div class="d-flex flex-wrap gap-2" id="teacherFilters">
                    <button class="btn btn-sm btn-dark rounded-pill px-3 filter-chip active" data-filter="all" data-type="teacher">الكل</button>
                    <% 
                        const colors = ['primary', 'success', 'danger', 'warning', 'info', 'dark', 'secondary'];
                        const uniqueTeachers = [...new Set(periods.map(p => p.teacher_name))];
                        uniqueTeachers.forEach((name, i) => { 
                            const color = colors[i % colors.length];
                    %>
                        <button class="btn btn-sm btn-outline-<%= color %> rounded-pill px-3 filter-chip" data-filter="<%= name %>" data-type="teacher"><%= name %></button>
                    <% }) %>
                </div>
            </div>
            <div class="col-md-6">
                <small class="text-muted d-block mb-1 fw-bold">تصفية حسب اليوم:</small>
                <div class="d-flex flex-wrap gap-2" id="dayFilters">
                    <button class="btn btn-sm btn-dark rounded-pill px-3 filter-chip active" data-filter="all" data-type="day">الكل</button>
                    <% 
                        const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
                        const dayArabic = { 'Monday': 'الاثنين', 'Tuesday': 'الثلاثاء', 'Wednesday': 'الأربعاء', 'Thursday': 'الخميس', 'Friday': 'الجمعة', 'Saturday': 'السبت' };
                        days.forEach(day => { 
                    %>
                        <button class="btn btn-sm btn-outline-secondary rounded-pill px-3 filter-chip" data-filter="<%= dayArabic[day] %>" data-type="day"><%= dayArabic[day] %></button>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>

<% 
    const periodArabic = { 1: 'الأولى', 2: 'الثانية', 3: 'الثالثة', 4: 'الرابعة', 5: 'الخامسة' };
    const dayArabicMap = { 'Monday': 'الاثنين', 'Tuesday': 'الثلاثاء', 'Wednesday': 'الأربعاء', 'Thursday': 'الخميس', 'Friday': 'الجمعة', 'Saturday': 'السبت' };
    const dayNamesEn = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
%>

<div class="timetable-container">
    <% classes.forEach(cls => { 
        const classPeriods = periods.filter(p => p.class_id === cls.id);
        if (classPeriods.length === 0) return; 
    %>
        <div class="class-timetable mb-5" data-class="<%= cls.name_ar %>">
            <div class="class-header bg-dark text-white p-3 text-center rounded-top fw-bold fs-4">
                صف: <%= cls.name_ar %>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered align-middle text-center mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th style="width: 15%;">اليوم / الحصة</th>
                            <% for(let i=1; i<=5; i++) { %>
                                <th style="width: 17%;"><%= periodArabic[i] %></th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% dayNamesEn.forEach(day => { %>
                            <% 
                                const dayPeriods = classPeriods.filter(p => p.day_of_week === day);
                                if (day === 'Saturday' && dayPeriods.length === 0) return; 
                            %>
                            <tr class="day-row" data-day="<%= dayArabicMap[day] %>">
                                <td class="fw-bold bg-light text-primary"><%= dayArabicMap[day] %></td>
                                <% for(let i=1; i<=5; i++) { 
                                    const period = dayPeriods.find(p => p.period_number == i);
                                %>
                                    <td class="p-0 position-relative cell-container" style="height: 90px;">
                                        <% if (period) { %>
                                            <div class="period-box p-2 h-100 d-flex flex-column justify-content-center" data-teacher="<%= period.teacher_name %>">
                                                <div class="subject-name fw-bold mb-1"><%= period.book_title || period.subject %></div>
                                                <div class="teacher-name small text-primary"><%= period.teacher_name %></div>
                                            </div>
                                        <% } %>
                                        <div class="h-100 d-flex align-items-center justify-content-center text-muted empty-dash <%= period ? 'd-none' : '' %>">
                                            <i class="bi bi-dash opacity-25"></i>
                                        </div>
                                    </td>
                                <% } %>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    <% }) %>
</div>

<style>
    .timetable-container { max-width: 1200px; margin: 0 auto; }
    .class-timetable { box-shadow: 0 10px 30px rgba(0,0,0,0.05); border-radius: 15px; overflow: hidden; border: 1px solid #eee; background: #fff; }
    .period-box { transition: all 0.2s; font-size: 0.85rem; line-height: 1.1; }
    .subject-name { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; color: #2c3e50; word-break: break-word; }
    .teacher-name { font-size: 0.7rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    @media (min-width: 992px) {
        .timetable-container { max-width: 100%; padding: 0 20px; }
        .period-box { font-size: 0.95rem; }
        .subject-name { -webkit-line-clamp: 1; white-space: nowrap; }
        .teacher-name { font-size: 0.8rem; }
    }
    .period-box:hover { background: #f8f9fa; }
    @media print {
        .no-print { display: none !important; }
        .class-timetable { break-inside: avoid; margin-bottom: 2cm !important; border: 2px solid #000 !important; box-shadow: none !important; }
        body { background: white !important; }
        .container { max-width: 100% !important; width: 100% !important; margin: 0 !important; padding: 0 !important; }
    }
</style>

<script>
let activeFilters = { teacher: 'all', day: 'all' };

document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', function() {
        const type = this.dataset.type;
        const filter = this.dataset.filter;
        activeFilters[type] = filter;

        // UI state
        document.querySelectorAll(`.filter-chip[data-type="${type}"]`).forEach(c => c.classList.remove('active', 'btn-dark', 'btn-primary', 'btn-success', 'btn-danger', 'btn-warning', 'btn-info', 'btn-secondary'));
        document.querySelectorAll(`.filter-chip[data-type="${type}"]`).forEach(c => c.classList.add('btn-outline-secondary')); 
        
        this.classList.add('active');
        this.classList.remove('btn-outline-secondary');
        this.classList.add('btn-dark');

        applyFilters();
    });
});

function applyFilters() {
    const dayRows = document.querySelectorAll('.day-row');
    const classBlocks = document.querySelectorAll('.class-timetable');

    dayRows.forEach(row => {
        const matchDay = activeFilters.day === 'all' || row.dataset.day === activeFilters.day;
        const boxes = row.querySelectorAll('.period-box');
        const dashes = row.querySelectorAll('.empty-dash');
        
        let hasMatch = false;
        boxes.forEach((box, i) => {
            const matchTeacher = activeFilters.teacher === 'all' || box.dataset.teacher === activeFilters.teacher;
            if (matchTeacher) {
                box.classList.remove('d-none');
                dashes[i].classList.add('d-none');
                hasMatch = true;
            } else {
                box.classList.add('d-none');
                dashes[i].classList.remove('d-none');
            }
        });

        // If filtering by teacher, a row stays visible if it has AT LEAST one period for that teacher
        // If filtering by day, it must also match the day
        if (matchDay && (activeFilters.teacher === 'all' || hasMatch)) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });

    // Hide entire classes if they become empty
    classBlocks.forEach(block => {
        const visibleRows = block.querySelectorAll('.day-row[style=""]');
        block.style.display = visibleRows.length > 0 ? '' : 'none';
    });
}
</script>

<%- include('partials/footer') %>
