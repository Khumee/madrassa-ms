                    </div>
                    <!-- Print-only header to show name clearly without toggle UI -->
                    <div class="class-header bg-dark text-white p-3 text-center rounded-top fw-bold fs-4 shadow-sm d-none d-print-block" style="background: linear-gradient(135deg, #1e3a8a, #0d9488) !important; box-shadow: inset 0 0 0 1000px #1e3a8a !important; color: white !important;">
                        <i class="bi bi-person-workspace me-2"></i><%= t.name %>
                    </div>
                <div class="table-responsive collapse" id="timetable-collapse-t-<%= t.id %>">
                    <table class="table table-bordered align-middle text-center mb-0" style="border-collapse: separate; border-spacing: 0;">
                        <thead class="bg-light">
                            <tr>
                                <th class="py-3 fw-bold text-muted border-bottom-0" style="width: 15%;">
                                    <span class="d-none d-md-inline"><%= __('Day_Period') %></span>
                                    <span class="d-md-none"><%= locals.lang === 'ur' ? 'دن' : 'اليوم' %></span>
                                </th>
                                <% for(let i=1; i<=maxPeriod; i++) { %>
                                    <th class="py-3 fw-bold text-muted border-bottom-0" style="width: <%= 85 / maxPeriod %>%;">
                                        <span class="d-none d-md-inline"><%= __(periodKeys[i] || 'Period_' + i) %></span>
                                        <span class="d-md-none"><%= i %></span>
                                    </th>
                                <% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% dayNamesEn.forEach(day => { %>
                                <%
                                    if (locals.selectedDay && locals.selectedDay !== day) return;
                                %>
                                <% 
                                    const dayPeriods = teacherPeriods.filter(p => p.day_of_week === day);
                                    if (dayPeriods.length === 0) return; 
                                %>
                                <tr class="day-row" data-day="<%= day %>">
                                    <td class="fw-bold bg-light text-primary border-end-0 py-3"><%= __(day) %></td>
                                    <% for(let i=1; i<=maxPeriod; i++) { 
                                        let period = dayPeriods.find(p => p.period_number == i);
                                         if (period && locals.selectedTeacherId && period.teacher_id != locals.selectedTeacherId) {
                                             period = null;
                                         }
                                    %>
                                        <td class="p-1 position-relative cell-container">
                                            <% if (period) { %>
                                                <% 
                                                    const palette = getTeacherPalette(period.teacher_name);
                                                %>
                                                <div class="period-box h-100 border-start border-4 shadow-sm" 
                                                      style="background: <%= palette.bg %>; color: <%= palette.text %>; border-color: <%= palette.border %> !important; box-shadow: inset 0 0 0 1000px <%= palette.bg %> !important;"
                                                      data-class="<%= period.class_name %>"
                                                      data-teacher="<%= period.teacher_name %>">
                                                     <!-- Book section: always visible -->
                                                     <div class="period-book-section">
                                                         <div class="subject-name fw-bold"><%= period.book_title || period.subject %></div>
                                                     </div>
                                                     <!-- Teacher section: always on desktop, collapsible on mobile -->
                                                     <div class="period-teacher-section">
                                                         <div class="teacher-label-row">
                                                             <span class="teacher-text" title="<%= __('Class_Prefix') %> <%= __(period.class_name) %>"><%= __('Class_Prefix') %> <%= __(period.class_name) %></span>
                                                         </div>
                                                     </div>
                                                     <% if (period.start_time) { %>
                                                         <div class="period-time d-none d-md-block">
                                                             <i class="bi bi-clock"></i> <%= period.start_time.substring(0,5) %> - <%= period.end_time.substring(0,5) %>
                                                         </div>
                                                     <% } %>
                                                 </div>
                                                <div class="h-100 d-flex align-items-center justify-content-center text-muted empty-dash rounded-3 d-none">
                                                    <i class="bi bi-dash-lg opacity-25"></i>
                                                </div>
                                            <% } else { %>
                                                <div class="h-100 d-flex align-items-center justify-content-center text-muted empty-dash rounded-3">
                                                    <i class="bi bi-dash-lg opacity-25"></i>
                                                </div>
                                            <% } %>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <% }) %>
    <% } else { %>
        <% classes.forEach(cls => {
            if (locals.selectedClassId && locals.selectedClassId != cls.id) return; 
            const classPeriods = periods.filter(p => p.class_id === cls.id);
            if (classPeriods.length === 0) return; 
        %>
            <div class="print-page-block" data-class="<%= cls.name_ar %>">
                <!-- Print Letterhead Header -->
                <div class="print-page-header d-none d-print-flex align-items-center justify-content-between mb-3 pb-2 border-bottom">
                    <div class="text-start">
                        <span class="text-muted small fw-bold" style="font-size: 0.85rem;"><%= locals.lang === 'ur' ? 'کلاسز کا ہفتہ وار شیڈول' : 'جدول الحصص الأسبوعي' %></span>
                    </div>
                    <div class="d-flex align-items-center gap-2 text-end">
                        <div class="me-2">
                            <h5 class="fw-bold text-primary mb-0" style="font-size: 1.1rem; color: #1e3a8a !important; font-family: 'Segoe UI', sans-serif;">كليّة العلوم الإسلامية</h5>
                            <span class="text-muted small fw-bold" style="font-size: 0.8rem;">أوقات الحصص الدراسية</span>
                        </div>
                        <img src="/logo.jpg" alt="Logo" style="height: 45px; border-radius: 6px; border: 1px solid #e2e8f0; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important;">
                    </div>
                </div>
                <div class="class-timetable mb-5">
                    <div class="class-header bg-dark text-white p-3 d-flex align-items-center justify-content-between rounded-top fw-bold fs-4 shadow-sm no-print" 
                         style="background: linear-gradient(135deg, #1e3a8a, #0d9488) !important; box-shadow: inset 0 0 0 1000px #1e3a8a !important; color: white !important; cursor: pointer;"
                         data-bs-toggle="collapse" 
                         data-bs-target="#timetable-collapse-c-<%= cls.id %>" 
                         aria-expanded="false">
                        <div>
                            <i class="bi bi-mortarboard-fill me-2"></i><%= __('Class_Prefix') %> <%= __(cls.name_ar) %>
                        </div>
                        <i class="bi bi-chevron-down toggle-chevron transition-all"></i>
                    </div>
                    <!-- Print-only header to show name clearly without toggle UI -->
                    <div class="class-header bg-dark text-white p-3 text-center rounded-top fw-bold fs-4 shadow-sm d-none d-print-block" style="background: linear-gradient(135deg, #1e3a8a, #0d9488) !important; box-shadow: inset 0 0 0 1000px #1e3a8a !important; color: white !important;">
                        <i class="bi bi-mortarboard-fill me-2"></i><%= __('Class_Prefix') %> <%= __(cls.name_ar) %>
                    </div>
                <div class="table-responsive collapse" id="timetable-collapse-c-<%= cls.id %>">
                    <table class="table table-bordered align-middle text-center mb-0" style="border-collapse: separate; border-spacing: 0;">
                        <thead class="bg-light">
                            <tr>
                                <th class="py-3 fw-bold text-muted border-bottom-0" style="width: 15%;">
                                    <span class="d-none d-md-inline"><%= __('Day_Period') %></span>
                                    <span class="d-md-none"><%= locals.lang === 'ur' ? 'دن' : 'اليوم' %></span>
                                </th>
                                <% for(let i=1; i<=maxPeriod; i++) { %>
                                    <th class="py-3 fw-bold text-muted border-bottom-0" style="width: <%= 85 / maxPeriod %>%;">
                                        <span class="d-none d-md-inline"><%= __(periodKeys[i] || 'Period_' + i) %></span>
                                        <span class="d-md-none"><%= i %></span>
                                    </th>
                                <% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% dayNamesEn.forEach(day => { %>
                                <%
                                    if (locals.selectedDay && locals.selectedDay !== day) return;
                                %>
                                <% 
                                    const dayPeriods = classPeriods.filter(p => p.day_of_week === day);
                                    if (dayPeriods.length === 0) return; 
                                %>
                                <tr class="day-row" data-day="<%= day %>">
                                    <td class="fw-bold bg-light text-primary border-end-0 py-3"><%= __(day) %></td>
                                    <% for(let i=1; i<=maxPeriod; i++) { 
                                        let period = dayPeriods.find(p => p.period_number == i);
                                         if (period && locals.selectedTeacherId && period.teacher_id != locals.selectedTeacherId) {
                                             period = null;
                                         }
                                    %>
                                        <td class="p-1 position-relative cell-container">
                                            <% if (period) { %>
                                                <% 
                                                    const palette = getTeacherPalette(period.teacher_name);
                                                %>
                                                <div class="period-box h-100 border-start border-4 shadow-sm" 
                                                      style="background: <%= palette.bg %>; color: <%= palette.text %>; border-color: <%= palette.border %> !important; box-shadow: inset 0 0 0 1000px <%= palette.bg %> !important;"
                                                      data-teacher="<%= period.teacher_name %>">
                                                     <!-- Book section: always visible -->
                                                     <div class="period-book-section">
                                                         <div class="subject-name fw-bold"><%= period.book_title || period.subject %></div>
                                                     </div>
                                                     <!-- Teacher section: always on desktop, collapsible on mobile -->
                                                     <div class="period-teacher-section">
                                                         <div class="teacher-label-row">
                                                             <span class="teacher-text" title="<%= period.teacher_name %>"><%= period.teacher_name %></span>
                                                         </div>
                                                     </div>
