<script>
function filterTimetable(type, value) {
    const url = new URL(window.location.href);
    if (!value) {
        url.searchParams.delete(type);
    } else {
        url.searchParams.set(type, value);
    }
    window.location.href = url.pathname + url.search;
}

function toggleTeacher(event, btn) {
    event.stopPropagation();
    const row = btn.closest('.teacher-label-row');
    if (!row) return;
    const textEl = row.querySelector('.teacher-text');
    if (textEl) {
        // Toggle Bootstrap d-none to show/hide
        textEl.classList.toggle('d-none');
        // Also force inline display when visible
        if (!textEl.classList.contains('d-none')) {
            textEl.style.display = 'inline';
        } else {
            textEl.style.display = '';
        }
    }
    btn.classList.toggle('expanded');
}
</script>

