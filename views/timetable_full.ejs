<%- include('partials/header') %>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h1 class="fw-bold text-primary mb-0">الجدول الدراسي العام</h1>
        <p class="text-muted">نظرة شاملة على جميع الحصص والمقررات</p>
    </div>
    <div class="col-md-6 text-start">
        <a href="/periods/manage" class="btn btn-outline-secondary rounded-pill px-4 me-2">
            <i class="bi bi-gear me-2"></i>تعديل الجدول
        </a>
        <a href="/" class="btn btn-outline-primary rounded-pill px-4">
            <i class="bi bi-house-door me-2"></i>الرئيسية
        </a>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-bordered align-middle mb-0 text-center" style="min-width: 1000px;">
                <thead class="table-primary">
                    <tr>
                        <th style="width: 100px;">اليوم / الحصة</th>
                        <% for(let i=1; i<=5; i++) { %>
                            <th>الحصة <%= i %></th>
                        <% } %>
                    </tr>
                </thead>
                <tbody>
                    <% 
                        const days = ['Saturday', 'Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'];
                        const dayArabic = {
                            'Saturday': 'السبت', 'Sunday': 'الأحد', 'Monday': 'الاثنين', 
                            'Tuesday': 'الثلاثاء', 'Wednesday': 'الأربعاء', 'Thursday': 'الخميس', 'Friday': 'الجمعة'
                        };
                    %>
                    <% days.forEach(day => { %>
                        <tr>
                            <td class="table-light fw-bold"><%= dayArabic[day] %></td>
                            <% for(let i=1; i<=5; i++) { 
                                const period = periods.find(p => p.day_of_week === day && p.period_number == i);
                            %>
                                <td class="p-2" style="height: 100px; width: 20%;">
                                    <% if (period) { %>
                                        <div class="p-2 rounded-3 bg-success-subtle border border-success-subtle h-100 d-flex flex-column justify-content-center">
                                            <div class="fw-bold text-dark small mb-1"><%= period.book_title || period.subject %></div>
                                            <div class="text-primary x-small fw-bold"><%= period.teacher_name %></div>
                                            <div class="text-muted x-small"><%= period.class_name %></div>
                                            <div class="text-muted" style="font-size: 0.6rem;"><%= period.start_time.substring(0,5) %></div>
                                        </div>
                                    <% } else { %>
                                        <div class="h-100 d-flex align-items-center justify-content-center text-muted-light">
                                            <i class="bi bi-dash"></i>
                                        </div>
                                    <% } %>
                                </td>
                            <% } %>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 0.7rem; }
    .text-muted-light { color: #e0e0e0; }
</style>

<%- include('partials/footer') %>
