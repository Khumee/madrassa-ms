<script>
let activeFilters = { teacher: 'all', day: 'all', class: 'all' };

document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', function() {
        const type = this.dataset.type;
        const filter = this.dataset.filter;
        activeFilters[type] = filter;

        // UI state
        document.querySelectorAll(`.filter-chip[data-type="${type}"]`).forEach(c => {
            c.classList.remove('active', 'btn-dark', 'btn-primary', 'btn-success', 'btn-danger', 'btn-warning', 'btn-info', 'btn-secondary', 'btn-indigo', 'btn-orange', 'btn-teal', 'btn-purple');
            
            // Restore outline color
            const match = c.getAttribute('class').match(/btn-outline-(\w+)/);
            if (!match) {
                const color = c.dataset.filter === 'all' ? 'dark' : (type === 'class' ? 'primary' : 'secondary');
                c.classList.add(`btn-outline-${color}`);
            }
        });
        
        this.classList.add('active');
        const colorMatch = this.classList.toString().match(/btn-outline-(\w+)/);
        const color = colorMatch ? colorMatch[1] : 'dark';
        this.classList.remove(`btn-outline-${color}`);
        this.classList.add(`btn-${color}`);

        applyFilters();
    });
});

function applyFilters() {
    const isTeacherView = <%= groupBy === 'teacher' ? 'true' : 'false' %>;
    const blocks = document.querySelectorAll('.print-page-block');
    const clean = (str) => str ? str.trim().replace(/\s+/g, ' ').replace(/ی/g, 'ي').replace(/ک/g, 'ك') : '';

    blocks.forEach(block => {
        let matchBlock = true;
        if (isTeacherView) {
            matchBlock = activeFilters.teacher === 'all' || clean(block.dataset.teacher) === clean(activeFilters.teacher);
        } else {
            matchBlock = activeFilters.class === 'all' || clean(block.dataset.class) === clean(activeFilters.class);
        }
        
        const dayRows = block.querySelectorAll('.day-row');
        let hasAnyVisibleRow = false;

        dayRows.forEach(row => {
            const matchDay = activeFilters.day === 'all' || row.dataset.day === activeFilters.day;
            const cells = row.querySelectorAll('.cell-container');
            
            let hasVisiblePeriodInRow = false;
            cells.forEach(cell => {
                const box = cell.querySelector('.period-box');
                const dash = cell.querySelector('.empty-dash');
                
                if (box) {
                    let matchBox = true;
                    if (isTeacherView) {
                        matchBox = activeFilters.class === 'all' || clean(box.dataset.class) === clean(activeFilters.class);
                    } else {
                        matchBox = activeFilters.teacher === 'all' || clean(box.dataset.teacher) === clean(activeFilters.teacher);
                    }
                    
                    if (matchBox) {
                        box.classList.remove('d-none');
                        if (dash) dash.classList.add('d-none');
                        hasVisiblePeriodInRow = true;
                    } else {
                        box.classList.add('d-none');
                        if (dash) dash.classList.remove('d-none');
                    }
                }
            });

            // Row is visible if it matches the day filter AND has a valid period match (if filter is set)
            const hasFilterActive = isTeacherView ? activeFilters.class !== 'all' : activeFilters.teacher !== 'all';
            if (matchDay && (!hasFilterActive || hasVisiblePeriodInRow)) {
                row.style.display = '';
                hasAnyVisibleRow = true;
            } else {
                row.style.display = 'none';
            }
        });

        // Hide the block if block filter doesn't match OR has no visible rows
        if (matchBlock && hasAnyVisibleRow) {
            block.style.display = '';
        } else {
            block.style.display = 'none';
        }
    });
}
</script>

