<%- include('partials/header') %>

<%
    // Helper function to generate visually distinct HSL background colors for teachers
    function getTeacherPalette(name) {
        // Strip honorific prefixes so teachers like "مولانا حبيب" and "مولانا حسن" don't collide
        let cleanName = name.replace(/^(مولانا|مفتی|حافظ|استاد|الشيخ|شیخ)\s+/g, '').trim();
        
        // Polynomial rolling hash
        let hash = 0;
        const p = 31;
        const m = 1e9 + 9;
        for (let i = 0; i < cleanName.length; i++) {
            hash = (hash * p + cleanName.charCodeAt(i)) % m;
        }
        
        const colorsPalette = [
            { bg: '#e0f2fe', text: '#0369a1', border: '#0ea5e9' }, // Soft Baby Blue
            { bg: '#dcfce7', text: '#15803d', border: '#22c55e' }, // Soft Mint Green
            { bg: '#ffedd5', text: '#c2410c', border: '#f97316' }, // Soft Peach Orange
            { bg: '#ffe4e6', text: '#9f1239', border: '#f43f5e' }, // Soft Rose Pink
            { bg: '#f3e8ff', text: '#6b21a8', border: '#a855f7' }, // Soft Lavender Purple
            { bg: '#fef9c3', text: '#854d0e', border: '#eab308' }, // Soft Banana Yellow
            { bg: '#ccfbf1', text: '#0f766e', border: '#14b8a6' }, // Soft Teal
            { bg: '#fae8ff', text: '#86198f', border: '#d946ef' }, // Soft Lilac
            { bg: '#ecfeff', text: '#155e75', border: '#06b6d4' }, // Soft Ice Cyan
            { bg: '#fee2e2', text: '#991b1b', border: '#f87171' }, // Soft Coral Red
            { bg: '#fef3c7', text: '#92400e', border: '#fbbf24' }, // Soft Apricot Gold
            { bg: '#f0fdf4', text: '#166534', border: '#4ade80' }, // Soft Sage Green
            { bg: '#e0e7ff', text: '#3730a3', border: '#6366f1' }, // Soft Slate Blue
            { bg: '#f5f5f4', text: '#44403c', border: '#a8a29e' }, // Soft Slate Gray
            { bg: '#f7fee7', text: '#3f6212', border: '#84cc16' }  // Soft Lime Green
        ];
        
        const index = Math.abs(hash) % colorsPalette.length;
        return colorsPalette[index];
    }
%>

<div class="row mb-4 align-items-center no-print">
    <div class="col-md-6">
        <h1 class="fw-bold text-primary mb-0"><%= __('All_Classes_Timetable') %></h1>
        <p class="text-muted"><%= __('Timetable_Overview') %></p>
    </div>
    <div class="col-md-6 text-start">
        <button class="btn btn-outline-primary rounded-pill px-4 me-2" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse">
            <i class="bi bi-filter me-2"></i><%= __('Filter') %>
        </button>
        <button onclick="window.print()" class="btn btn-dark rounded-pill px-4 me-2">
            <i class="bi bi-printer me-2"></i><%= __('Print') %>
        </button>
        <% if (session && ['ناظم', 'مدير', 'عريب'].includes(session.role)) { %>
            <a href="/periods/manage" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-gear me-2"></i><%= __('Manage') %>
            </a>
        <% } %>
    </div>
</div>

<!-- Expandable Filter Chips -->
<div class="collapse no-print" id="filterCollapse">
    <div class="card shadow-sm border-0 rounded-4 mb-4" style="background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
        <div class="card-body p-3">
            <div class="row g-4">
                <div class="col-md-4 border-end">
                    <small class="text-muted d-block mb-2 fw-bold"><%= __('Filter_By_Teacher') %></small>
                    <div class="d-flex flex-wrap gap-2" id="teacherFilters">
                        <button class="btn btn-sm btn-dark rounded-pill px-3 filter-chip active" data-filter="all" data-type="teacher"><%= __('All') %></button>
                        <% 
                            const colors = ['primary', 'success', 'danger', 'warning', 'info', 'indigo', 'orange', 'teal', 'purple'];
                            const uniqueTeachers = [...new Set(periods.map(p => p.teacher_name))];
                            uniqueTeachers.forEach((name, i) => { 
                                const color = colors[i % colors.length];
                        %>
                            <button class="btn btn-sm btn-outline-<%= color %> rounded-pill px-3 filter-chip" data-filter="<%= name %>" data-type="teacher"><%= name %></button>
                        <% }) %>
                    </div>
                </div>
                <div class="col-md-4 border-end">
                    <small class="text-muted d-block mb-2 fw-bold"><%= __('Filter_By_Day') %></small>
                    <div class="d-flex flex-wrap gap-2" id="dayFilters">
                        <button class="btn btn-sm btn-dark rounded-pill px-3 filter-chip active" data-filter="all" data-type="day"><%= __('All') %></button>
                        <% 
                            const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
                            days.forEach(day => { 
                        %>
                            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3 filter-chip" data-filter="<%= day %>" data-type="day"><%= __(day) %></button>
                        <% }) %>
                    </div>
                </div>
                <div class="col-md-4">
                    <small class="text-muted d-block mb-2 fw-bold"><%= __('Filter_By_Class') %></small>
                    <div class="d-flex flex-wrap gap-2" id="classFilters">
                        <button class="btn btn-sm btn-dark rounded-pill px-3 filter-chip active" data-filter="all" data-type="class"><%= __('All') %></button>
                        <% classes.forEach(cls => { %>
                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3 filter-chip" data-filter="<%= cls.name_ar %>" data-type="class"><%= __(cls.name_ar) %></button>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<% 
    const periodKeys = { 1: 'Period_1', 2: 'Period_2', 3: 'Period_3', 4: 'Period_4', 5: 'Period_5', 6: 'Period_6', 7: 'Period_7' };
    const dayNamesEn = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
    
    // Determine the maximum period number dynamically (defaulting to at least 5)
    let maxPeriod = 5;
    periods.forEach(p => {
        if (p.period_number > maxPeriod) maxPeriod = p.period_number;
    });
%>

<div class="timetable-container-wide">
    <% classes.forEach(cls => { 
        const classPeriods = periods.filter(p => p.class_id === cls.id);
        if (classPeriods.length === 0) return; 
    %>
        <div class="class-timetable mb-5" data-class="<%= cls.name_ar %>">
            <div class="class-header bg-dark text-white p-3 text-center rounded-top fw-bold fs-4 shadow-sm">
                <i class="bi bi-mortarboard-fill me-2"></i><%= __('Class_Prefix') %> <%= __(cls.name_ar) %>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered align-middle text-center mb-0" style="border-collapse: separate; border-spacing: 0;">
                    <thead class="bg-light">
                        <tr>
                            <th class="py-3 fw-bold text-muted border-bottom-0" style="width: 15%;"><%= __('Day_Period') %></th>
                            <% for(let i=1; i<=maxPeriod; i++) { %>
                                <th class="py-3 fw-bold text-muted border-bottom-0" style="width: <%= 85 / maxPeriod %>%;"><%= __(periodKeys[i] || 'Period_' + i) %></th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% dayNamesEn.forEach(day => { %>
                            <% 
                                const dayPeriods = classPeriods.filter(p => p.day_of_week === day);
                                if (day === 'Saturday' && dayPeriods.length === 0) return; 
                            %>
                            <tr class="day-row" data-day="<%= day %>">
                                <td class="fw-bold bg-light text-primary border-end-0 py-3"><%= __(day) %></td>
                                <% for(let i=1; i<=maxPeriod; i++) { 
                                    const period = dayPeriods.find(p => p.period_number == i);
                                %>
                                    <td class="p-1 position-relative cell-container" style="height: 105px;">
                                        <% if (period) { %>
                                            <% 
                                                const palette = getTeacherPalette(period.teacher_name);
                                            %>
                                            <div class="period-box p-3 h-100 d-flex flex-column justify-content-center border-start border-4 shadow-sm" 
                                                 style="background: <%= palette.bg %>; color: <%= palette.text %>; border-color: <%= palette.border %> !important;" 
                                                 data-teacher="<%= period.teacher_name %>">
                                                <div class="subject-name fw-bold mb-1" style="font-size: 0.95rem; line-height: 1.2;"><%= period.book_title || period.subject %></div>
                                                <div class="teacher-name small fw-bold opacity-75" style="font-size: 0.8rem;"><%= period.teacher_name %></div>
                                                <% if (period.start_time) { %>
                                                    <div class="period-time mt-1 small opacity-50 fw-semibold" style="font-size: 0.72rem;">
                                                        <i class="bi bi-clock me-1"></i><%= period.start_time.substring(0,5) %> - <%= period.end_time.substring(0,5) %>
                                                    </div>
                                                <% } %>
                                            </div>
                                        <% } else { %>
                                            <div class="h-100 d-flex align-items-center justify-content-center text-muted empty-dash rounded-3">
                                                <i class="bi bi-dash-lg opacity-25"></i>
                                            </div>
                                        <% } %>
                                    </td>
                                <% } %>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    <% }) %>
</div>

<style>
    .timetable-container-wide { width: 100%; margin: 0 auto; }
    
    .class-timetable { 
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.04); 
        border-radius: 20px; 
        overflow: hidden; 
        border: 1px solid rgba(224, 224, 224, 0.6); 
        background: #fff; 
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .class-timetable:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 45px rgba(0, 0, 0, 0.08);
    }
    
    .class-header {
        background: linear-gradient(135deg, #1e293b, #0f172a);
        color: #fff;
        font-family: 'Outfit', 'Inter', sans-serif;
        letter-spacing: 0.5px;
    }

    .table th {
        font-family: 'Outfit', 'Inter', sans-serif;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        background-color: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
    }

    .day-row td.fw-bold {
        background-color: #f8fafc !important;
        font-family: 'Outfit', 'Inter', sans-serif;
        border-right: 1px solid #e2e8f0;
    }

    .period-box { 
        transition: all 0.25s ease; 
        font-size: 0.85rem; 
        border-radius: 10px;
        margin: 1px;
    }
    
    .period-box:hover { 
        transform: scale(1.03); 
        box-shadow: 0 8px 20px rgba(0,0,0,0.08); 
        cursor: pointer;
    }
    
    .empty-dash {
        background-color: #fcfcfc;
        border: 1px dashed rgba(224, 224, 224, 0.4);
    }

    /* Print Styles */
    @media print {
        .no-print { display: none !important; }
        .class-timetable { 
            break-inside: avoid; 
            margin-bottom: 2cm !important; 
            border: 2px solid #333 !important; 
            box-shadow: none !important; 
            border-radius: 0 !important; 
            transform: none !important;
        }
        .class-header {
            background: #333 !important;
            color: #fff !important;
            border-radius: 0 !important;
        }
        body { background: white !important; }
        .timetable-container-wide { padding: 0 !important; }
        .period-box {
            border: 1px solid #ccc !important;
            background: #fff !important;
            color: #000 !important;
            border-left: 5px solid #000 !important;
            box-shadow: none !important;
            transform: none !important;
        }
    }
</style>

<script>
let activeFilters = { teacher: 'all', day: 'all', class: 'all' };

document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', function() {
        const type = this.dataset.type;
        const filter = this.dataset.filter;
        activeFilters[type] = filter;

        // UI state
        document.querySelectorAll(`.filter-chip[data-type="${type}"]`).forEach(c => {
            c.classList.remove('active', 'btn-dark', 'btn-primary', 'btn-success', 'btn-danger', 'btn-warning', 'btn-info', 'btn-secondary', 'btn-indigo', 'btn-orange', 'btn-teal', 'btn-purple');
            
            // Restore outline color
            const match = c.getAttribute('class').match(/btn-outline-(\w+)/);
            if (!match) {
                const color = c.dataset.filter === 'all' ? 'dark' : (type === 'class' ? 'primary' : 'secondary');
                c.classList.add(`btn-outline-${color}`);
            }
        });
        
        this.classList.add('active');
        const colorMatch = this.classList.toString().match(/btn-outline-(\w+)/);
        const color = colorMatch ? colorMatch[1] : 'dark';
        this.classList.remove(`btn-outline-${color}`);
        this.classList.add(`btn-${color}`);

        applyFilters();
    });
});

function applyFilters() {
    const classBlocks = document.querySelectorAll('.class-timetable');

    classBlocks.forEach(block => {
        const className = block.dataset.class;
        const matchClass = activeFilters.class === 'all' || className === activeFilters.class;
        
        const dayRows = block.querySelectorAll('.day-row');
        let hasAnyVisibleRowInClass = false;

        dayRows.forEach(row => {
            const matchDay = activeFilters.day === 'all' || row.dataset.day === activeFilters.day;
            const boxes = row.querySelectorAll('.period-box');
            const dashes = row.querySelectorAll('.empty-dash');
            
            let hasVisiblePeriodInRow = false;
            boxes.forEach((box, i) => {
                const matchTeacher = activeFilters.teacher === 'all' || box.dataset.teacher === activeFilters.teacher;
                if (matchTeacher) {
                    box.classList.remove('d-none');
                    dashes[i].classList.add('d-none');
                    hasVisiblePeriodInRow = true;
                } else {
                    box.classList.add('d-none');
                    dashes[i].classList.remove('d-none');
                }
            });

            // Row is visible if it matches the day filter AND has a teacher match (if a teacher is selected)
            if (matchDay && (activeFilters.teacher === 'all' || hasVisiblePeriodInRow)) {
                row.style.display = '';
                hasAnyVisibleRowInClass = true;
            } else {
                row.style.display = 'none';
            }
        });

        // Hide the whole class block if it doesn't match the class filter OR has no visible rows
        if (matchClass && hasAnyVisibleRowInClass) {
            block.style.display = '';
        } else {
            block.style.display = 'none';
        }
    });
}
</script>

<%- include('partials/footer') %>
