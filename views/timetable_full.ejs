                                                <div class="h-100 d-flex align-items-center justify-content-center text-muted empty-dash rounded-3">
                                                    <i class="bi bi-dash-lg opacity-25"></i>
                                                </div>
                                            <% } %>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <% }) %>
    <% } %>
</div>

<style>
    .timetable-container-wide { width: 100%; margin: 0 auto; }

    /* ── Period box base (all screen sizes) ─────────────────────── */
    .period-box {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 10px 12px;
        border-radius: 10px;
        margin: 2px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        height: 100%;
    }
    .period-box:hover {
        transform: scale(1.02);
        box-shadow: 0 6px 18px rgba(0,0,0,0.1);
        cursor: pointer;
    }
    .period-book-section {
        flex: 1;
    }
    .subject-name {
        font-size: 0.88rem;
        line-height: 1.3;
        font-weight: 700;
        word-wrap: break-word;
        word-break: break-word;
        white-space: normal;
    }
    .period-teacher-section {
        margin-top: 5px;
    }
    .teacher-label-row {
        display: block;
        margin-top: 3px;
    }
    .teacher-text {
        font-size: 0.78rem;
        font-weight: 600;
        opacity: 0.85;
        white-space: normal;
        word-break: break-word;
    }
    .period-time {
        font-size: 0.72rem;
        opacity: 0.55;
        margin-top: 5px;
        font-weight: 600;
    }
    .cell-container { height: 115px; }

    /* ── Mobile: compact, readable, no overflow ──────────────────── */
    @media (max-width: 768px) {
        .table-responsive {
            overflow-x: auto !important;
            -webkit-overflow-scrolling: touch;
        }
        /* Day column: sticky, wide enough for short Urdu/Arabic day names */
        .table th:first-child, .table td:first-child {
            min-width: 50px !important;
            max-width: 60px !important;
            width: 54px !important;
            position: sticky;
            left: 0;
            background-color: #f8fafc !important;
            z-index: 2;
            border-right: 2px solid #dee2e6 !important;
            font-size: 0.7rem !important;
            padding: 4px 3px !important;
        }
        /* Period header cells */
        .table th:not(:first-child) {
            min-width: 70px !important;
            font-size: 0.65rem !important;
            padding: 4px 2px !important;
        }
        /* Data cells */
        .table td:not(:first-child) {
            min-width: 70px !important;
            padding: 2px !important;
        }
        .cell-container {
            height: auto !important;
            min-height: 64px !important;
        }
        .period-box {
            padding: 5px 6px !important;
            border-radius: 6px !important;
            margin: 1px !important;
            min-height: 60px !important;
        }
        .subject-name {
            font-size: 0.68rem !important;
            line-height: 1.3 !important;
            /* Clamp to max 2 lines so cells stay uniform height */
            display: -webkit-box !important;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        /* Teacher toggle button: reset all browser styles, just show icon */
        .teacher-label-row {
            display: block !important;
            margin-top: 2px !important;
            width: 100% !important;
        }
        .teacher-text {
            display: block !important;
