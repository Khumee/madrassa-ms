                                                                <div class="col-6">
                                                                     <span class="text-muted"><%= __('Range_Label') %></span>
                                                                     <strong class="text-dark" dir="ltr"><%= __('Current_Page') %> <%= latest.startedAt %> ← <%= latest.endedAt %></strong>
                                                                </div>
                                                                <div class="col-6">
                                                                     <span class="text-muted"><%= __('Completed_Pages_Count') %></span>
                                                                     <strong class="text-success">+<%= latest.pagesCompleted %> ص</strong>
                                                                </div>
                                                            </div>
                                                            <div class="d-flex justify-content-between align-items-center pt-2 border-top flex-wrap gap-2" style="font-size: 0.78rem;">
                                                                 <span><%= __('Registrar_Label') %> <strong class="text-dark"><%= latest.updaterName %></strong></span>
                                                                 <span class="text-muted"><%= __('Total_Range_Label') %> <%= b.start_page %> - <%= b.end_page %></span>
