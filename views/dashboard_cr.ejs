                                        </thead>
                                        <tbody>
                                            <% personalAttendanceList.forEach(row => { %>
                                                <tr>
                                                    <td class="px-4 py-3 fw-bold text-dark border-0" style="font-size: 0.88rem;">
                                                        <%= row.date instanceof Date ? row.date.toISOString().split('T')[0] : String(row.date).split('T')[0] %>
                                                    </td>
                                                    <td class="px-4 py-3 text-center border-0">
                                                        <span class="badge rounded-pill px-3 py-1.5 bg-<%= 
                                                            row.status === 'present' ? 'success' : 
                                                            row.status === 'absent' ? 'danger' : 
                                                            row.status === 'leave' ? 'warning' : 'info' 
                                                        %>" style="font-size: 0.78rem;">
                                                            <%= row.status === 'present' ? __('Status_Present') : 
                                                                row.status === 'absent' ? __('Status_Absent') : 
                                                                row.status === 'leave' ? __('Status_Leave') : __('Status_Online') %>
                                                        </span>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } else { %>
                                <div class="text-center py-5 text-muted border rounded-4 bg-light">
                                    <i class="bi bi-calendar-x fs-2 d-block mb-2 text-secondary opacity-50"></i>
                                    <%= __('No_Attendance_Records_Range') %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Student Right Column: Assigned Textbook Lesson Metrics -->
                <div class="col-md-6">
                    <div class="bg-transparent border-0 shadow-none h-100">
                        <div class="p-3 pb-2 border-0 bg-transparent">
                            <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-book-half me-2 text-success"></i><%= __('My_Current_Books') %></h5>
                        </div>
                        <div class="p-0">
                            <% if (personalBooks.length > 0) { %>
                                <div class="d-flex flex-column gap-4">
                                    <% personalBooks.forEach(b => { 
                                        const total = b.end_page - b.start_page;
                                        const completed = b.current_page - b.start_page;
                                        const percentage = total > 0 ? Math.min(100, Math.max(0, Math.round((completed / total) * 100))) : 0;
                                    %>
                                        <div class="mb-3 border rounded-4 bg-white shadow-xs overflow-hidden transition-all hover-scale-sm">
                                            <!-- Clickable Header (Always Visible) -->
                                            <div class="p-3 d-flex justify-content-between align-items-center flex-wrap gap-2 cursor-pointer bg-light bg-opacity-25" 
                                                 role="button"
                                                 data-bs-toggle="collapse" 
                                                 data-bs-target="#bookCollapse_<%= b.id || b.assignment_id %>" 
                                                 aria-expanded="false"
                                                 style="cursor: pointer; user-select: none;">
                                                
                                                <div class="d-flex align-items-center gap-3">
                                                    <!-- Chevron Indicator -->
                                                    <i class="bi bi-chevron-down text-muted transition-rotate"></i>
                                                    
                                                    <div class="text-end">
                                                        <h5 class="fw-bold text-success mb-1" style="font-size: 1.15rem;"><%= b.book_title %></h5>
                                                        <small class="text-secondary opacity-75">
                                                            <i class="bi bi-person me-1"></i> <%= __('Teacher_Prefix') %> <%= b.teacher_name %>
                                                        </small>
                                                    </div>
                                                </div>
                                                
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="badge bg-success-subtle text-success fs-6 px-3 py-2 rounded-pill fw-bold">
                                                        <%= __('Current_Page') %> <%= b.current_page %>
                                                    </span>
                                                    <span class="badge bg-success text-white rounded-pill px-2.5 py-1.5 fw-bold" style="font-size: 0.85rem;"><%= percentage %>%</span>
                                                </div>
                                            </div>
                                            
                                            <!-- Collapsible Body (Hidden by Default) -->
                                            <div class="collapse" id="bookCollapse_<%= b.id || b.assignment_id %>">
                                                <div class="p-3 border-top bg-light bg-opacity-10">
                                                    <!-- Spacious Metrics Grid -->
                                                    <div class="row g-3 text-end mb-3">
                                                        <!-- Total Pages Range -->
                                                        <div class="col-6 col-sm-6">
                                                            <div class="p-3 rounded-4 bg-white border border-light-subtle shadow-xs h-100">
                                                                <div class="text-muted small mb-1" style="font-size: 0.78rem;">
                                                                    <i class="bi bi-book-half text-primary me-1"></i> <%= __('Total_Syllabus_Range') %>
                                                                </div>
                                                                <div class="fw-bold text-dark" style="font-size: 1.05rem;" dir="rtl">
                                                                    <%= __('From_Page') %> <span class="badge bg-primary-subtle text-primary rounded px-2"><%= b.start_page %></span> <%= __('To_Page') %> <span class="badge bg-primary-subtle text-primary rounded px-2"><%= b.end_page %></span>
                                                                </div>
                                                                <div class="text-secondary small mt-1 opacity-75" style="font-size: 0.72rem;">
                                                                    (<%= __('Total_Pages_Count') %>: <%= b.end_page - b.start_page + 1 %>)
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <!-- Pages Remaining -->
                                                        <div class="col-6 col-sm-6">
                                                            <div class="p-3 rounded-4 bg-white border border-light-subtle shadow-xs h-100">
                                                                <div class="text-muted small mb-1" style="font-size: 0.78rem;">
                                                                    <i class="bi bi-compass text-success me-1"></i> <%= __('Studied_And_Completed') %>
                                                                </div>
                                                                <div class="fw-bold text-success" style="font-size: 1.05rem;" dir="rtl">
                                                                    <%= __('Current_Page') %> <span class="badge bg-success-subtle text-success rounded px-2"><%= b.current_page %></span>
                                                                </div>
                                                                <div class="text-secondary small mt-1 opacity-75" style="font-size: 0.72rem;">
                                                                    (<%= __('Remaining_Pages') %>: <%= Math.max(0, b.end_page - b.current_page) %>)
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Sleek Gradient Progress Bar -->
                                                    <div class="progress mb-2 rounded-pill shadow-xs" style="height: 10px; background-color: #e2e8f0; overflow: hidden;">
                                                        <div class="progress-bar rounded-pill" role="progressbar" style="width: <%= percentage %>%; background: linear-gradient(90deg, #10b981, #059669);" aria-valuenow="<%= percentage %>" aria-valuemin="0" aria-valuemax="100"></div>
                                                    </div>
                                                    <div class="d-flex justify-content-between text-muted mb-3" style="font-size: 0.75rem;">
                                                        <span><%= __('Total_Progress_Percentage') %> (<%= percentage %>%)</span>
                                                        <span class="text-success fw-bold"><%= __('Current_Page') %> <%= b.current_page %> <%= __('Page_Of') %> <%= b.end_page %></span>
                                                    </div>

                                                    <!-- Recent Lesson Details (Fully integrated inline) -->
                                                    <% if (b.detailed_history && b.detailed_history.length > 0) { 
                                                        const latest = b.detailed_history[0];
                                                    %>
                                                        <div class="p-3 rounded-4 bg-white border border-light-subtle shadow-xs text-end" style="border: 1px dashed #cbd5e1 !important; font-size: 0.82rem;">
                                                            <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2 flex-wrap gap-2">
                                                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2 py-1"><i class="bi bi-clock me-1"></i><%= __('Last_Lesson_Recent') %></span>
                                                                <span class="text-muted small"><%= latest.date %></span>
