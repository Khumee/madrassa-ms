<%- include('partials/header') %>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-bold mb-0">لوحة تحكم مسؤول الصف - <%= classInfo.name_ar %></h2>
                            <p class="text-muted">عرض حضور الفصل اليوم</p>
                        </div>
                        <a href="/profile/change-password" class="btn btn-outline-primary rounded-pill">تغيير كلمة المرور</a>
                    </div>

                    <h4 class="mb-3">الحضور اليوم: <%= new Date().toLocaleDateString('ar-EG') %></h4>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>الرقم</th>
                                    <th>اسم الطالب</th>
                                    <th>الحالة اليوم</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% students.forEach(student => { %>
                                    <tr>
                                        <td><%= student.roll_number %></td>
                                        <td><%= student.name %></td>
                                        <td>
                                            <span class="badge rounded-pill bg-<%= 
                                                student.status === 'present' ? 'success' : 
                                                student.status === 'absent' ? 'danger' : 
                                                student.status === 'leave' ? 'warning' : 'info' 
                                            %>">
                                                <%= student.status === 'present' ? 'حاضر' : 
                                                    student.status === 'absent' ? 'غائب' : 
                                                    student.status === 'leave' ? 'إجازة' : 
                                                    student.status === 'online' ? 'أونلاين' : 'غير محدد' %>
                                            </span>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
