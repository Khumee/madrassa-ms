</div>

<script>
    const classId = <%= classId %>;
    const todayDate = '<%= todayDate %>';

    // Local Two-Stage Attendance Object
    let localAttendance = {};
    let isSubmitted = <%= students.some(s => s.status) ? 'true' : 'false' %>;

    document.addEventListener('DOMContentLoaded', () => {
        // 1. Populate local attendance object with initial loaded database values
        <% students.forEach(student => { %>
            if ('<%= student.status %>') {
                localAttendance[<%= student.id %>] = '<%= student.status %>';
            }
        <% }) %>
        
        // 2. Render localized status classes for tactile buttons
        refreshLocalStatusHighlights();
        
        // 3. Initialize dynamic submitted lock UI state
        updateAttendanceUIState();
    });

    function refreshLocalStatusHighlights() {
        document.querySelectorAll('.student-card').forEach(card => {
            const studentId = card.getAttribute('data-student-id');
            const status = localAttendance[studentId];
            const group = card.querySelector('.status-btn-group');
            
            group.querySelectorAll('.status-btn').forEach(b => {
                b.classList.remove('active');
            });
            
            if (status) {
                group.classList.add('btn-row-active');
                const activeBtn = group.querySelector(`.status-btn[data-status="${status}"]`);
                if (activeBtn) activeBtn.classList.add('active');
            } else {
                group.classList.remove('btn-row-active');
            }
        });
    }

    function markLocalStatus(studentId, status, btn) {
        if (isSubmitted) return; // Prevent clicking when locked
        
        // Update local object
        localAttendance[studentId] = status;
        
        // Refresh CSS transitions
        refreshLocalStatusHighlights();
    }

    function updateAttendanceUIState() {
        const listContainer = document.getElementById('studentAttendanceList');
        const submitBtn = document.getElementById('submitAttendanceBtn');
        const editBtn = document.getElementById('editAttendanceBtn');
        const badgeContainer = document.getElementById('attendanceStatusBadge');
        
        if (isSubmitted) {
            // Apply greyed out locked state
            listContainer.classList.add('attendance-submitted');
            submitBtn.classList.add('d-none');
            editBtn.classList.remove('d-none');
            badgeContainer.innerHTML = `<span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-1.5"><i class="bi bi-shield-fill-check me-1"></i>✓ تم تسليم الحضور للأعلى</span>`;
            
            // Block mouse clicking
            document.querySelectorAll('.status-btn').forEach(btn => {
                btn.style.pointerEvents = 'none';
            });
        } else {
            // Unlocked active state
            listContainer.classList.remove('attendance-submitted');
            submitBtn.classList.remove('d-none');
            editBtn.classList.add('d-none');
            badgeContainer.innerHTML = `<span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-3 py-1.5"><i class="bi bi-exclamation-circle-fill me-1"></i>كشف غير مسلّم</span>`;
            
            // Enable mouse clicking
            document.querySelectorAll('.status-btn').forEach(btn => {
                btn.style.pointerEvents = 'auto';
            });
        }
    }

    function enableAttendanceEditing() {
        isSubmitted = false;
        updateAttendanceUIState();
    }

    async function submitAllAttendance() {
        // Validate if all students are marked before posting
        const studentIds = [<%- students.map(s => s.id).join(',') %>];
        const unmarked = studentIds.filter(id => !localAttendance[id]);
        
        if (unmarked.length > 0) {
            const confirmSave = confirm('تنبيه: لم يتم تحديد حضور لبعض الطلاب. هل تريد تقديم حضور الصف وإرساله على أي حال؟');
            if (!confirmSave) return;
        }

        try {
            const res = await fetch('/attendance/students/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    date: todayDate,
                    classId: classId,
                    attendance: localAttendance
                })
            });
            const data = await res.json();
            if (data.success) {
                isSubmitted = true;
                updateAttendanceUIState();
                alert('✅ تم حفظ وإرسال كشف حضور الطلاب بنجاح!');
            } else {
                alert('❌ فشل حفظ كشف حضور الطلاب');
            }
        } catch (err) {
            console.error(err);
            alert('❌ حدث خطأ أثناء الاتصال بالسيرفر');
        }
    }

    async function toggleTeacherAttendance(teacherId, switchInput, periodId) {
        const teacherCards = document.querySelectorAll(`.teacher-period-card[data-teacher-id="${teacherId}"]`);
        let checkedCount = 0;
        teacherCards.forEach(card => {
            const checkbox = card.querySelector('input[type="checkbox"]');
            if (checkbox && checkbox.checked) {
                checkedCount++;
            }
        });

        const tcard = document.getElementById(`tcard_${periodId}`);
        if (tcard) {
            if (switchInput.checked) {
                tcard.classList.add('timeline-card-active');
            } else {
                tcard.classList.remove('timeline-card-active');
            }
        }

        const updateStatusText = (checked) => {
            const tstatus = document.getElementById(`tstatus_${periodId}`);
            if (tstatus) {
                if (checked) {
                    tstatus.innerHTML = `<span class="text-success fw-semibold"><i class="bi bi-check-circle-fill me-1"></i> حاضر للحصة</span>`;
                } else {
                    tstatus.innerHTML = `<span class="text-danger fw-semibold"><i class="bi bi-x-circle-fill me-1"></i> غائب / لم يؤخذ الحصة</span>`;
                }
            }
        };

        updateStatusText(switchInput.checked);

        try {
            const res = await fetch('/attendance/teachers/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    date: todayDate,
                    attendance: { [teacherId]: checkedCount }
                })
            });
            const data = await res.json();
            if (!data.success) {
                alert('فشل تعديل حضور المعلم');
                switchInput.checked = !switchInput.checked;
                if (tcard) tcard.classList.toggle('timeline-card-active');
                updateStatusText(switchInput.checked);
            }
        } catch (err) {
            console.error(err);
            alert('حدث خطأ أثناء الحفظ');
            switchInput.checked = !switchInput.checked;
            if (tcard) tcard.classList.toggle('timeline-card-active');
            updateStatusText(switchInput.checked);
        }
    }

    function adjustPage(periodId, delta) {
        const input = document.getElementById(`input_${periodId}`);
        if (!input) return;
        
        let currentVal = parseInt(input.value) || 0;
        let min = parseInt(input.min) || 0;
        let max = parseInt(input.max) || 0;
        
        if (currentVal < min) {
            currentVal = min;
        } else if (currentVal > max) {
            currentVal = max;
        }
        
        const val = currentVal + delta;
        if (val >= min && val <= max) {
            input.value = val;
            input.dispatchEvent(new Event('change'));
        } else {
            alert(`تنبيه: لا يمكن تخطي المدى المحدد المسموح به لهذا الكتاب (${min} - ${max})`);
        }
    }

    async function updateBookProgress(assignmentId, inputField) {
        const pageNumber = inputField.value;
        const min = parseInt(inputField.min);
        const max = parseInt(inputField.max);

        if (pageNumber < min || pageNumber > max) {
            alert(`خطأ: رقم الصفحة يجب أن يكون بين ${min} و ${max}`);
            inputField.value = inputField.getAttribute('data-last-valid') || min;
            return;
        }

        try {
            const res = await fetch('/book/update-progress', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ assignmentId, pageNumber })
            });
            const data = await res.json();
            if (data.success) {
                inputField.setAttribute('data-last-valid', pageNumber);

                const label = document.getElementById(`up_label_${assignmentId}`);
                if (label) {
                    const nowStr = new Date().toLocaleTimeString('<%= locals.lang === "ur" ? "ur-PK" : "ar-EG" %>', { hour: '2-digit', minute: '2-digit' });
                    label.innerHTML = `<span><i class="bi bi-clock-history me-1"></i><%= __('Last_Updated') %>: <%= __('Now') %> (${nowStr})</span>`;
                }

                const container = inputField.parentElement;
                container.style.borderColor = '#10b981';
                container.style.backgroundColor = '#ecfdf5';
                setTimeout(() => {
                    container.style.borderColor = '#e2e8f0';
                    container.style.backgroundColor = '#ffffff';
                }, 1000);
            } else {
                alert('حدث خطأ: ' + (data.error || 'فشل التحديث'));
            }
        } catch (err) {
            console.error(err);
            alert('حدث خطأ أثناء حفظ تقدم الكتاب');
        }
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
    <% classBooks.forEach(book => { %>
        <% if (book.progress_history && book.progress_history.length > 0) { %>
            try {
                const ctx_<%= book.assignment_id %> = document.getElementById('miniChart_<%= book.assignment_id %>').getContext('2d');
                new Chart(ctx_<%= book.assignment_id %>, {
                    type: 'line',
                    data: {
                        labels: <%- JSON.stringify(book.progress_history.map(h => h.date)) %>,
                        datasets: [{
                            label: '<%= book.book_title %>',
                            data: <%- JSON.stringify(book.progress_history.map(h => h.page_number)) %>,
                            borderColor: '#4f46e5',
                            backgroundColor: 'rgba(79, 70, 229, 0.08)',
                            tension: 0.25,
                            fill: true,
                            pointRadius: 3,
                            pointHoverRadius: 5,
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: { rtl: true }
                        },
                        scales: {
                            x: { 
                                grid: { display: false },
                                ticks: { font: { size: 9 }, display: false }
                            },
                            y: { 
                                beginAtZero: false,
                                grid: { color: '#f1f5f9' },
                                ticks: { font: { size: 9 } }
                            }
                        }
                    }
                });
            } catch (chartErr) {
                console.error('Error initializing chart for book <%= book.assignment_id %>:', chartErr);
            }
        <% } %>
    <% }) %>
});
</script>

