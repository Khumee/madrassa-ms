<%- include('partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-primary text-white p-4 rounded-top-4">
                <h2 class="fw-bold mb-0">إضافة طالب جديد</h2>
            </div>
            <div class="card-body p-4">
                <form action="/students/add" method="POST">
                    <div class="mb-4">
                        <label class="form-label fw-bold">اسم الطالب الكامل</label>
                        <input type="text" name="name" class="form-control form-control-lg rounded-3" 
                               placeholder="مثال: محمد عبد الله" required>
                        <div class="form-text">سيتم إنشاء حساب مستخدم تلقائياً لهذا الطالب.</div>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold">الفصل</label>
                        <select name="classId" class="form-select form-select-lg rounded-3" required>
                            <option value="">اختر الفصل...</option>
                            <% classes.forEach(cls => { %>
                                <option value="<%= cls.id %>"><%= cls.name_ar %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="alert alert-info border-0 rounded-3">
                        <i class="bi bi-info-circle me-2"></i>
                        سيتم توليد <strong>رقم القيد</strong> تلقائياً بعد الحفظ.
                    </div>

                    <div class="d-grid mt-5">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold">
                            حفظ البيانات
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
