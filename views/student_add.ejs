<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إضافة طالب جديد</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <div class="logo">كليّة العلوم الإسلامية</div>
        <a href="/" class="btn btn-primary">الرئيسية</a>
    </nav>

    <div class="container">
        <div class="card">
            <h1>إضافة طالب جديد</h1>
            <form action="/students/add" method="POST">
                <div style="margin-bottom: 15px;">
                    <label>اسم الطالب</label>
                    <input type="text" name="name" class="btn" style="width: 100%; text-align: right; background: #f9f9f9; border: 1px solid #ddd; color: #333;" required>
                </div>
                <div style="margin-bottom: 15px;">
                    <label>الفصل</label>
                    <select name="classId" class="btn" style="width: 100%; text-align: right; background: #f9f9f9; border: 1px solid #ddd; color: #333;" required>
                        <% classes.forEach(cls => { %>
                            <option value="<%= cls.id %>"><%= cls.name_ar %></option>
                        <% }) %>
                    </select>
                </div>
                <div style="margin-bottom: 25px;">
                    <label>رقم القيد</label>
                    <input type="text" name="rollNumber" class="btn" style="width: 100%; text-align: right; background: #f9f9f9; border: 1px solid #ddd; color: #333;">
                </div>
                <button type="submit" class="btn btn-secondary" style="width: 100%;">إضافة</button>
            </form>
        </div>
    </div>
</body>
</html>
