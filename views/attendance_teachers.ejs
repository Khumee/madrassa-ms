    <%- include('partials/header') %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <div class="row mb-4">
        <div class="col-md-12">
            <!-- Premium Navigation and Header Card -->
            <div class="card shadow-sm border-0 rounded-4 p-4 text-white" style="background: linear-gradient(135deg, #4f46e5 0%, #3730a3 100%);">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <h1 class="fw-bold mb-1"><i class="bi bi-calendar3-week me-2"></i>سجل حضور المعلمين الأسبوعي</h1>
                        <p class="text-white-50 mb-0">أسبوع يبدأ من: <strong class="text-white"><%= startOfWeek %></strong></p>
                    </div>
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <!-- Date Picker -->
                        <div class="d-flex align-items-center gap-2 bg-white bg-opacity-10 px-3 py-1 rounded-pill" style="border: 1px solid rgba(255,255,255,0.2);">
                            <label class="small text-white-50 mb-0 text-nowrap"><i class="bi bi-calendar-event me-1"></i>انتقال للتاريخ:</label>
                            <input type="date" class="form-control form-control-sm bg-transparent border-0 text-white fw-bold p-0" 
                                value="<%= selectedDate %>" 
                                style="width: 130px; cursor: pointer; color-scheme: dark;" 
                                id="datePicker">
                        </div>
                        <!-- Navigation Buttons -->
                        <div class="btn-group shadow-sm" role="group">
                            <a href="/teachers?date=<%= prevWeekDate %>" class="btn btn-outline-light rounded-start-pill px-3 fw-bold">
                                <i class="bi bi-chevron-right me-1"></i>الأسبوع السابق
                            </a>
                            <a href="/teachers?date=<%= nextWeekDate %>" class="btn btn-outline-light rounded-end-pill px-3 fw-bold">
                                الأسبوع التالي<i class="bi bi-chevron-left ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-white p-4 border-0 d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <h4 class="fw-bold mb-0 text-indigo"><i class="bi bi-grid-3x3-gap me-2"></i>جدول المتابعة الأسبوعي</h4>
                        <small class="text-muted">مقارنة الحصص المنجزة بالحصص المجدولة خلال الأسبوع</small>
                    </div>
                    <!-- Status Legend -->
                    <div class="d-flex align-items-center gap-3 flex-wrap" style="font-size: 0.8rem;">
                        <span class="d-flex align-items-center gap-1"><span class="badge bg-success" style="width: 12px; height: 12px; border-radius: 50%; padding: 0;">&nbsp;</span> مكتمل</span>
                        <span class="d-flex align-items-center gap-1"><span class="badge bg-purple" style="width: 12px; height: 12px; border-radius: 50%; padding: 0; background-color: #8b5cf6;">&nbsp;</span> إضافي / تعويض</span>
                        <span class="d-flex align-items-center gap-1"><span class="badge bg-danger" style="width: 12px; height: 12px; border-radius: 50%; padding: 0;">&nbsp;</span> نقص / غياب</span>
                        <span class="d-flex align-items-center gap-1"><span class="badge bg-warning text-dark" style="width: 12px; height: 12px; border-radius: 50%; padding: 0;">&nbsp;</span> غير مسجل بعد</span>
                    </div>
                </div>
                
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle text-end mb-0" style="min-width: 900px;">
                            <thead class="table-light">
                                <tr class="border-bottom" style="border-bottom: 2px solid #e2e8f0 !important;">
                                    <th class="p-4 fw-bold text-dark" style="width: 220px;">اسم المعلم</th>
                                    <% days.forEach(day => { %>
                                        <th class="p-4 text-center">
                                            <div class="fw-bold text-indigo"><%= day.dayNameAr %></div>
                                            <small class="text-muted"><%= day.formattedDate %></small>
                                        </th>
                                    <% }) %>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (reportData.length === 0) { %>
                                    <tr>
                                        <td colspan="7" class="text-center py-5 text-muted">
                                            <i class="bi bi-people text-muted" style="font-size: 3rem;"></i>
                                            <p class="mt-3 fw-bold">لا يوجد معلمون مسجلون في النظام حالياً.</p>
                                        </td>
                                    </tr>
                                <% } else { %>
                                    <% reportData.forEach(teacher => { %>
                                        <tr class="border-bottom">
                                            <!-- Teacher Name column -->
                                            <td class="p-4 fw-bold text-dark">
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="avatar bg-indigo bg-opacity-10 text-indigo rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 38px; height: 38px; font-size: 1rem;">
                                                        <%= teacher.name.charAt(0) %>
                                                    </div>
                                                    <div>
                                                        <span class="d-block text-dark fw-bold"><%= teacher.name %></span>
                                                    </div>
                                                </div>
                                            </td>
                                            
                                            <!-- Weekly Columns Saturday-Thursday -->
                                            <% teacher.days.forEach(day => { %>
                                                <td class="p-4 text-center">
                                                    <% if (day.scheduled > 0) { %>
                                                        <!-- Has scheduled classes -->
                                                        <% if (day.taken === null) { %>
                                                            <!-- Not marked yet -->
                                                            <div class="badge bg-warning-subtle text-warning border border-warning border-opacity-25 rounded-pill px-3 py-2 fw-semibold w-100" style="font-size: 0.8rem;">
                                                                <i class="bi bi-dash-circle me-1"></i>غير مسجل (<%= day.scheduled %>)
                                                            </div>
                                                        <% } else if (day.taken === 0) { %>
                                                            <!-- Absent/No class taken -->
                                                            <div class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2 fw-semibold w-100" style="font-size: 0.8rem;">
                                                                <i class="bi bi-x-circle me-1"></i>غائب / 0 حصص
                                                            </div>
                                                        <% } else if (day.taken === day.scheduled) { %>
                                                            <!-- Complete / On time -->
                                                            <div class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2 fw-semibold w-100" style="font-size: 0.8rem;">
                                                                <i class="bi bi-check-circle me-1"></i>منجز <%= day.taken %>/<%= day.scheduled %>
                                                            </div>
                                                        <% } else if (day.taken > day.scheduled) { %>
                                                            <!-- Extra Makeup Classes -->
                                                            <div class="badge text-purple bg-purple bg-opacity-10 border border-purple border-opacity-25 rounded-pill px-3 py-2 fw-semibold w-100" style="font-size: 0.8rem; color: #8b5cf6; border-color: rgba(139, 92, 246, 0.25);">
                                                                <i class="bi bi-plus-circle me-1"></i>إضافي <%= day.taken %>/<%= day.scheduled %>
                                                            </div>
                                                        <% } else { %>
                                                            <!-- Under / Shortage -->
                                                            <div class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2 fw-semibold w-100" style="font-size: 0.8rem;">
                                                                <i class="bi bi-exclamation-circle me-1"></i>نقص <%= day.taken %>/<%= day.scheduled %>
                                                            </div>
                                                        <% } %>
                                                    <% } else { %>
                                                        <!-- No scheduled classes -->
                                                        <% if (day.taken > 0) { %>
                                                            <!-- Extra Makeup on free day! -->
                                                            <div class="badge text-purple bg-purple bg-opacity-10 border border-purple border-opacity-25 rounded-pill px-3 py-2 fw-semibold w-100" style="font-size: 0.8rem; color: #8b5cf6; border-color: rgba(139, 92, 246, 0.25);">
                                                                <i class="bi bi-arrow-repeat me-1"></i>تعويضي (+<%= day.taken %>)
                                                            </div>
                                                        <% } else { %>
                                                            <!-- No class at all -->
                                                            <span class="text-white-50 font-monospace">-</span>
                                                        <% } %>
                                                    <% } %>
                                                </td>
                                            <% }) %>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('datePicker').addEventListener('change', function() {
            window.location.href = `/teachers?date=${this.value}`;
        });
    </script>

    <style>
        .text-indigo {
            color: #4f46e5 !important;
        }
        .bg-indigo {
            background-color: #4f46e5 !important;
        }
    </style>

    <%- include('partials/footer') %>
