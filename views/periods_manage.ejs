<%- include('partials/header') %>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h1 class="fw-bold text-primary mb-0">إدارة الجدول الدراسي</h1>
        <p class="text-muted">توزيع الحصص والكتب على الأيام والفترات</p>
    </div>
    <div class="col-md-6 text-start">
        <a href="/periods/full" class="btn btn-success rounded-pill px-4 me-2">
            <i class="bi bi-calendar3 me-2"></i>عرض الجدول كاملاً
        </a>
        <a href="/" class="btn btn-outline-primary rounded-pill px-4">
            <i class="bi bi-house-door me-2"></i>الرجوع للوحة التحكم
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-header bg-primary text-white rounded-top-4 p-3">
                <h5 class="mb-0">إضافة حصة جديدة</h5>
            </div>
            <div class="card-body p-4">
                <form action="/periods/add" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold">توزيع الكتاب (Assignment)</label>
                        <select name="assignmentId" id="assignmentSelect" class="form-select" required onchange="updateFieldsFromAssignment()">
                            <option value="">اختر التوزيع...</option>
                            <% assignments.forEach(a => { %>
                                <option value="<%= a.id %>" data-teacher-id="<%= a.teacher_id %>" data-class-id="<%= a.class_id %>">
                                    <%= a.teacher_name %> - <%= a.book_title %> (<%= a.class_name %>)
                                </option>
                            <% }) %>
                        </select>
                        <input type="hidden" name="teacherId" id="teacherIdInput">
                        <input type="hidden" name="classId" id="classIdInput">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">اليوم</label>
                        <select name="dayOfWeek" class="form-select" required>
                            <option value="Saturday">السبت</option>
                            <option value="Sunday">الأحد</option>
                            <option value="Monday">الاثنين</option>
                            <option value="Tuesday">الثلاثاء</option>
                            <option value="Wednesday">الأربعاء</option>
                            <option value="Thursday">الخميس</option>
                            <option value="Friday">الجمعة</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">رقم الحصة</label>
                            <select name="periodNumber" class="form-select" id="addPeriodNumber" onchange="autoFillTimes('add')" required>
                                <% for(let i=1; i<=5; i++) { %>
                                    <option value="<%= i %>">الحصة <%= i %></option>
                                <% } %>
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">المادة (اختياري)</label>
                            <input type="text" name="subject" class="form-control" placeholder="أدخل المادة...">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">وقت البدء</label>
                            <input type="time" name="startTime" id="addStartTime" class="form-control" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">وقت الانتهاء</label>
                            <input type="time" name="endTime" id="addEndTime" class="form-control" required>
                        </div>
                    </div>

                    <div class="d-grid mt-2">
                        <button type="submit" class="btn btn-primary rounded-pill py-2 fw-bold">حفظ الحصة</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white p-4 border-0">
                <h5 class="fw-bold mb-0 text-primary">الجدول الحالي</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-end">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4">اليوم</th>
                                <th>الحصة</th>
                                <th>الأستاذ</th>
                                <th>الفصل</th>
                                <th>الكتاب / المادة</th>
                                <th class="px-4 text-center">الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% 
                                const dayArabic = {
                                    'Saturday': 'السبت',
                                    'Sunday': 'الأحد',
                                    'Monday': 'الاثنين',
                                    'Tuesday': 'الثلاثاء',
                                    'Wednesday': 'الأربعاء',
                                    'Thursday': 'الخميس',
                                    'Friday': 'الجمعة'
                                };
                            %>
                            <% periods.forEach(p => { %>
                                <tr>
                                    <td class="px-4 fw-bold text-dark"><%= dayArabic[p.day_of_week] || p.day_of_week %></td>
                                    <td>
                                        <span class="badge bg-secondary-subtle text-secondary border rounded-pill">
                                            <%= p.period_number || 'غير محدد' %>
                                        </span>
                                    </td>
                                    <td><%= p.teacher_name %></td>
                                    <td><%= p.class_name %></td>
                                    <td>
                                        <div class="fw-bold"><%= p.book_title || p.subject || 'غير محدد' %></div>
                                        <small class="text-muted"><%= p.start_time.substring(0,5) %> - <%= p.end_time.substring(0,5) %></small>
                                    </td>
                                    <td class="px-4 text-center">
                                        <button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1" 
                                                onclick="openEditModal(<%= JSON.stringify(p) %>)">
                                            تعديل
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3" 
                                                onclick="deletePeriod(<%= p.id %>)">
                                            حذف
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if (periods.length === 0) { %>
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">لا توجد حصص مسجلة حالياً</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Period Modal -->
<div class="modal fade" id="editPeriodModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title text-white">تعديل الحصة</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="editPeriodForm" method="POST">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">توزيع الكتاب</label>
                        <select name="assignmentId" id="editAssignmentId" class="form-select" required>
                            <% assignments.forEach(a => { %>
                                <option value="<%= a.id %>"><%= a.teacher_name %> - <%= a.book_title %> (<%= a.class_name %>)</option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">رقم الحصة</label>
                        <select name="periodNumber" id="editPeriodNumber" class="form-select" onchange="autoFillTimes('edit')" required>
                            <% for(let i=1; i<=5; i++) { %>
                                <option value="<%= i %>">الحصة <%= i %></option>
                            <% } %>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">وقت البدء</label>
                            <input type="time" name="startTime" id="editStartTime" class="form-control" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">وقت الانتهاء</label>
                            <input type="time" name="endTime" id="editEndTime" class="form-control" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">حفظ التغييرات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function openEditModal(period) {
    const modal = new bootstrap.Modal(document.getElementById('editPeriodModal'));
    document.getElementById('editPeriodForm').action = `/periods/edit/${period.id}`;
    document.getElementById('editAssignmentId').value = period.assignment_id || '';
    document.getElementById('editPeriodNumber').value = period.period_number || 1;
    document.getElementById('editStartTime').value = period.start_time.substring(0,5);
    document.getElementById('editEndTime').value = period.end_time.substring(0,5);
    modal.show();
}

function autoFillTimes(type) {
    const pNum = document.getElementById(type === 'add' ? 'addPeriodNumber' : 'editPeriodNumber').value;
    const startTimeInput = document.getElementById(type === 'add' ? 'addStartTime' : 'editStartTime');
    const endTimeInput = document.getElementById(type === 'add' ? 'addEndTime' : 'editEndTime');

    const times = {
        1: { start: '18:00', end: '18:40' },
        2: { start: '18:40', end: '19:20' },
        3: { start: '19:40', end: '20:20' },
        4: { start: '20:20', end: '21:00' },
        5: { start: '21:00', end: '21:40' }
    };

    if (times[pNum]) {
        startTimeInput.value = times[pNum].start;
        endTimeInput.value = times[pNum].end;
    }
}

// Initial fill for add form
window.addEventListener('DOMContentLoaded', () => {
    if (document.getElementById('addPeriodNumber')) autoFillTimes('add');
});

function updateFieldsFromAssignment() {
    const select = document.getElementById('assignmentSelect');
    const option = select.options[select.selectedIndex];
    if (option.value) {
        document.getElementById('teacherIdInput').value = option.dataset.teacherId;
        document.getElementById('classIdInput').value = option.dataset.classId;
    }
}

async function deletePeriod(id) {
    if (!confirm('هل أنت متأكد من حذف هذه الحصة؟')) return;
    const res = await fetch(`/periods/delete/${id}`, { method: 'POST' });
    if ((await res.json()).success) {
        location.reload();
    } else {
        alert('حدث خطأ أثناء الحذف');
    }
}
</script>

<%- include('partials/footer') %>
