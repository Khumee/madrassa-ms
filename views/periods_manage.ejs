<%- include('partials/header') %>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h1 class="fw-bold text-primary mb-0">إدارة الجدول الدراسي</h1>
        <p class="text-muted">توزيع الحصص والكتب على الأيام والفترات</p>
    </div>
    <div class="col-md-6 text-start">
        <a href="/periods/full" class="btn btn-success rounded-pill px-4 me-2">
            <i class="bi bi-calendar3 me-2"></i>عرض الجدول كاملاً
        </a>
        <a href="/" class="btn btn-outline-primary rounded-pill px-4">
            <i class="bi bi-house-door me-2"></i>الرجوع للوحة التحكم
        </a>
    </div>
</div>

<% 
    const dayArabic = {
        'Saturday': 'السبت', 'Sunday': 'الأحد', 'Monday': 'الاثنين', 
        'Tuesday': 'الثلاثاء', 'Wednesday': 'الأربعاء', 'Thursday': 'الخميس', 'Friday': 'الجمعة'
    };
%>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-header bg-primary text-white rounded-top-4 p-3">
                <h5 class="mb-0">إضافة حصة جديدة</h5>
            </div>
            <div class="card-body p-4">
                <form action="/periods/add" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold">توزيع الكتاب (Assignment)</label>
                        <select name="assignmentId" id="assignmentSelect" class="form-select" required onchange="updateFieldsFromAssignment()">
                            <option value="">اختر التوزيع...</option>
                            <% assignments.forEach(a => { %>
                                <option value="<%= a.id %>" data-teacher-id="<%= a.teacher_id %>" data-class-id="<%= a.class_id %>">
                                    <%= a.teacher_name %> - <%= a.book_title %> (<%= a.class_name %>)
                                </option>
                            <% }) %>
                        </select>
                        <input type="hidden" name="teacherId" id="teacherIdInput">
                        <input type="hidden" name="classId" id="classIdInput">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">اليوم</label>
                        <select name="dayOfWeek" class="form-select" required>
                            <option value="Saturday">السبت</option>
                            <option value="Sunday">الأحد</option>
                            <option value="Monday">الاثنين</option>
                            <option value="Tuesday">الثلاثاء</option>
                            <option value="Wednesday">الأربعاء</option>
                            <option value="Thursday">الخميس</option>
                            <option value="Friday">الجمعة</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">رقم الحصة</label>
                            <select name="periodNumber" class="form-select" id="addPeriodNumber" onchange="autoFillTimes('add')" required>
                                <% for(let i=1; i<=5; i++) { %>
                                    <option value="<%= i %>">الحصة <%= i %></option>
                                <% } %>
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">المادة (اختياري)</label>
                            <input type="text" name="subject" class="form-control" placeholder="أدخل المادة...">
                        </div>
                    </div>

                    <div class="row d-none">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">وقت البدء</label>
                            <input type="time" name="startTime" id="addStartTime" class="form-control">
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">وقت الانتهاء</label>
                            <input type="time" name="endTime" id="addEndTime" class="form-control">
                        </div>
                    </div>

                    <div class="d-grid mt-2">
                        <button type="submit" class="btn btn-primary rounded-pill py-2 fw-bold">حفظ الحصة</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-5">
            <div class="card-header bg-white p-4 border-0">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="card-title fw-bold mb-0">الجدول الحالي</h3>
                    <div class="btn-group rounded-pill overflow-hidden border">
                        <a href="/periods/manage?groupBy=day" class="btn btn-sm <%= groupBy === 'day' ? 'btn-primary' : 'btn-white text-muted' %> px-3">حسب اليوم</a>
                        <a href="/periods/manage?groupBy=teacher" class="btn btn-sm <%= groupBy === 'teacher' ? 'btn-primary' : 'btn-white text-muted' %> px-3">حسب الأستاذ</a>
                    </div>
                </div>
                
                <!-- Filter Chips -->
                <div class="filters-container">
                    <% if (groupBy !== 'day') { %>
                    <div class="mb-2">
                        <small class="text-muted d-block mb-1">تصفية حسب الأستاذ:</small>
                        <div class="d-flex flex-wrap gap-2" id="teacherFilters">
                            <button class="btn btn-sm btn-dark rounded-pill px-3 filter-chip active" data-filter="all" data-type="teacher">الكل</button>
                            <% 
                                const colors = ['primary', 'success', 'danger', 'warning', 'info', 'dark', 'secondary'];
                                const uniqueTeachers = [...new Set(periods.map(p => p.teacher_name))];
                                uniqueTeachers.forEach((name, i) => { 
                                    const color = colors[i % colors.length];
                            %>
                                <button class="btn btn-sm btn-outline-<%= color %> rounded-pill px-3 filter-chip" data-filter="<%= name %>" data-type="teacher"><%= name %></button>
                            <% }) %>
                        </div>
                    </div>
                    <% } %>
                    <div>
                        <small class="text-muted d-block mb-1">تصفية حسب اليوم:</small>
                        <div class="d-flex flex-wrap gap-2" id="dayFilters">
                            <button class="btn btn-sm btn-dark rounded-pill px-3 filter-chip active" data-filter="all" data-type="day">الكل</button>
                            <% 
                                const uniqueDays = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
                                uniqueDays.forEach(day => { 
                            %>
                                <button class="btn btn-sm btn-outline-secondary rounded-pill px-3 filter-chip" data-filter="<%= dayArabic[day] %>" data-type="day"><%= dayArabic[day] %></button>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="px-4" style="width: 15%;">الحصة</th>
                                <th style="width: 25%;"><%= groupBy === 'teacher' ? 'اليوم' : 'الأستاذ' %></th>
                                <th style="width: 15%;">الفصل</th>
                                <th style="width: 30%;">الكتاب / المادة</th>
                                <th class="px-4 text-center" style="width: 15%;">الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                                <% 
                                let lastGroup = '';
                                periods.forEach(p => { 
                                    const currentGroup = groupBy === 'teacher' ? p.teacher_name : dayArabic[p.day_of_week];
                                    if (currentGroup !== lastGroup) {
                                        lastGroup = currentGroup;
                            %>
                                <tr class="table-secondary group-header" data-group="<%= currentGroup %>">
                                    <td colspan="5" class="px-4 fw-bold text-primary bg-primary-subtle border-0">
                                        <i class="bi <%= groupBy === 'teacher' ? 'bi-person-badge' : 'bi-calendar-event' %> me-2"></i>
                                        <%= currentGroup %>
                                    </td>
                                </tr>
                            <% } %>
                                <tr class="period-row" data-teacher="<%= p.teacher_name %>" data-day="<%= dayArabic[p.day_of_week] %>">
                                    <td class="px-4">
                                        <span class="badge bg-secondary-subtle text-secondary border rounded-pill">
                                            الحصة <%= p.period_number || 'غير محدد' %>
                                        </span>
                                    </td>
                                    <td><%= groupBy === 'teacher' ? dayArabic[p.day_of_week] : p.teacher_name %></td>
                                    <td><%= p.class_name %></td>
                                    <td>
                                        <div class="subject-text-wrap fw-bold text-dark"><%= p.book_title || p.subject || 'غير محدد' %></div>

                                    </td>
                                    <td class="px-4 text-center">
                                        <button class="btn btn-sm btn-outline-primary rounded-circle p-2 lh-1 me-1" 
                                                onclick='openEditModal(<%- JSON.stringify(p) %>)' title="تعديل">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-circle p-2 lh-1" 
                                                onclick="deletePeriod(<%= p.id %>)" title="حذف">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if (periods.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">لا توجد حصص مسجلة حالياً</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Period Modal -->
<div class="modal fade" id="editPeriodModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title text-white">تعديل الحصة</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="editPeriodForm" method="POST">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">توزيع الكتاب</label>
                        <select name="assignmentId" id="editAssignmentId" class="form-select" required>
                            <% assignments.forEach(a => { %>
                                <option value="<%= a.id %>"><%= a.teacher_name %> - <%= a.book_title %> (<%= a.class_name %>)</option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">رقم الحصة</label>
                        <select name="periodNumber" id="editPeriodNumber" class="form-select" onchange="autoFillTimes('edit')" required>
                            <% for(let i=1; i<=5; i++) { %>
                                <option value="<%= i %>">الحصة <%= i %></option>
                            <% } %>
                        </select>
                    </div>
                    <div class="row d-none">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">وقت البدء</label>
                            <input type="time" name="startTime" id="editStartTime" class="form-control">
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">وقت الانتهاء</label>
                            <input type="time" name="endTime" id="editEndTime" class="form-control">
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">إلغاء</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">حفظ التغييرات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function openEditModal(period) {
    const modal = new bootstrap.Modal(document.getElementById('editPeriodModal'));
    document.getElementById('editPeriodForm').action = `/periods/edit/${period.id}`;
    document.getElementById('editAssignmentId').value = period.assignment_id || '';
    document.getElementById('editPeriodNumber').value = period.period_number || 1;
    document.getElementById('editStartTime').value = period.start_time.substring(0,5);
    document.getElementById('editEndTime').value = period.end_time.substring(0,5);
    modal.show();
}

function autoFillTimes(type) {
    const pNum = document.getElementById(type === 'add' ? 'addPeriodNumber' : 'editPeriodNumber').value;
    const startTimeInput = document.getElementById(type === 'add' ? 'addStartTime' : 'editStartTime');
    const endTimeInput = document.getElementById(type === 'add' ? 'addEndTime' : 'editEndTime');

    const times = {
        1: { start: '18:00', end: '18:40' },
        2: { start: '18:40', end: '19:20' },
        3: { start: '19:40', end: '20:20' },
        4: { start: '20:20', end: '21:00' },
        5: { start: '21:00', end: '21:40' }
    };

    if (times[pNum]) {
        startTimeInput.value = times[pNum].start;
        endTimeInput.value = times[pNum].end;
    }
}

// Initial fill for add form
window.addEventListener('DOMContentLoaded', () => {
    if (document.getElementById('addPeriodNumber')) autoFillTimes('add');
});

function updateFieldsFromAssignment() {
    const select = document.getElementById('assignmentSelect');
    const option = select.options[select.selectedIndex];
    if (option.value) {
        document.getElementById('teacherIdInput').value = option.dataset.teacherId;
        document.getElementById('classIdInput').value = option.dataset.classId;
    }
}

async function deletePeriod(id) {
    if (!confirm('هل أنت متأكد من حذف هذه الحصة؟')) return;
    const res = await fetch(`/periods/delete/${id}`, { method: 'POST' });
    if ((await res.json()).success) {
        location.reload();
    } else {
        alert('حدث خطأ أثناء الحذف');
    }
}

// Filtering Logic
let activeFilters = { teacher: 'all', day: 'all' };

document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', function() {
        const type = this.dataset.type;
        const filter = this.dataset.filter;
        
        // Update active filters
        activeFilters[type] = filter;
        
        // Update UI state
        document.querySelectorAll(`.filter-chip[data-type="${type}"]`).forEach(c => {
            c.classList.remove('active', 'btn-dark', 'btn-primary', 'btn-success', 'btn-danger', 'btn-warning', 'btn-info', 'btn-secondary');
            // Restore original outline color
            const originalColor = c.getAttribute('class').match(/btn-outline-(\w+)/);
            if (!originalColor) {
                const colorMatch = c.dataset.filter === 'all' ? 'dark' : (c.classList.toString().match(/btn-(\w+)/) || [null, 'secondary'])[1];
                c.classList.add(`btn-outline-${colorMatch}`);
            }
        });
        
        this.classList.add('active');
        const colorMatch = this.classList.toString().match(/btn-outline-(\w+)/);
        const color = colorMatch ? colorMatch[1] : 'dark';
        this.classList.remove(`btn-outline-${color}`);
        this.classList.add(`btn-${color}`);

        applyFilters();
    });
});

function applyFilters() {
    const rows = document.querySelectorAll('.period-row');
    const headers = document.querySelectorAll('.group-header');
    
    rows.forEach(row => {
        const matchTeacher = activeFilters.teacher === 'all' || row.dataset.teacher === activeFilters.teacher;
        const matchDay = activeFilters.day === 'all' || row.dataset.day === activeFilters.day;
        
        if (matchTeacher && matchDay) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });

    // Hide empty group headers
    headers.forEach(header => {
        let next = header.nextElementSibling;
        let hasVisible = false;
        while (next && !next.classList.contains('group-header')) {
            if (next.style.display !== 'none') {
                hasVisible = true;
                break;
            }
            next = next.nextElementSibling;
        }
        header.style.display = hasVisible ? '' : 'none';
    });
}
</script>

<%- include('partials/footer') %>
