<%- include('partials/header') %>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h1 class="fw-bold text-primary mb-0"><%= __('Manage_Timetable_Header') %></h1>
        <p class="text-muted"><%= __('Timetable_Header_Sub') %></p>
    </div>
    <div class="col-md-6 text-start">
        <form action="/periods/generate-auto" method="POST" class="d-inline" onsubmit="return confirm('<%= __('Confirm_Auto_Generate') %>')">
            <button type="submit" class="btn btn-warning rounded-pill px-4 me-2 text-dark fw-bold">
                <i class="bi bi-cpu me-2"></i><%= __('Auto_Generate_Timetable') %>
            </button>
        </form>
        <a href="/periods/full" class="btn btn-success rounded-pill px-4 me-2">
            <i class="bi bi-calendar3 me-2"></i><%= __('View_Full_Timetable') %>
        </a>
        <a href="/" class="btn btn-outline-primary rounded-pill px-4">
            <i class="bi bi-house-door me-2"></i><%= __('Back_To_Dashboard') %>
        </a>
    </div>
</div>

<% if (typeof generateSuccess !== 'undefined' && generateSuccess === 'true') { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-4 shadow-sm p-4 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2 fs-5"></i><%= __('Timetable_Generated_Success') %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<% 
    const dayNames = ['Saturday', 'Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'];
%>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-header bg-primary text-white rounded-top-4 p-3">
                <h5 class="mb-0"><%= __('Add_New_Period') %></h5>
            </div>
            <div class="card-body p-4">
                <form action="/periods/add" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold"><%= __('Book_Assignment') %></label>
                        <select name="assignmentId" id="assignmentSelect" class="form-select" required onchange="updateFieldsFromAssignment()">
                            <option value=""><%= __('Select_Assignment') %></option>
                            <% assignments.forEach(a => { %>
                                <option value="<%= a.id %>" data-teacher-id="<%= a.teacher_id %>" data-class-id="<%= a.class_id %>">
                                    <%= a.teacher_name %> - <%= a.book_title %> (<%= a.class_name %>)
                                </option>
                            <% }) %>
                        </select>
                        <input type="hidden" name="teacherId" id="teacherIdInput">
                        <input type="hidden" name="classId" id="classIdInput">
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold"><%= __('Day') %></label>
                        <select name="dayOfWeek" class="form-select" required>
                            <% dayNames.forEach(day => { %>
                                <option value="<%= day %>"><%= __(day) %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold"><%= __('Period_Number') %></label>
                            <select name="periodNumber" class="form-select" id="addPeriodNumber" onchange="autoFillTimes('add')" required>
                                <% for(let i=1; i<=7; i++) { %>
                                    <option value="<%= i %>"><%= i <= 5 ? __('Period_Label') + ' ' + i : __('Extra_Period') + ' ' + (i - 5) %></option>
                                <% } %>
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold"><%= __('Subject_Optional') %></label>
                            <input type="text" name="subject" class="form-control" placeholder="<%= __('Enter_Subject_Placeholder') %>">
                        </div>
                    </div>

                    <div class="row d-none">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold"><%= __('Start_Time') %></label>
                            <input type="time" name="startTime" id="addStartTime" class="form-control">
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold"><%= __('End_Time') %></label>
                            <input type="time" name="endTime" id="addEndTime" class="form-control">
                        </div>
                    </div>

                    <div class="d-grid mt-2">
                        <button type="submit" class="btn btn-primary rounded-pill py-2 fw-bold"><%= __('Save_Period') %></button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-5">
            <div class="card-header bg-white p-4 border-0">
                <div class="d-flex justify-content-between align-items-center">
                    <h3 class="card-title fw-bold mb-0"><%= __('Current_Timetable') %></h3>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary btn-sm rounded-pill px-3" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse">
                            <i class="bi bi-filter me-1"></i><%= __('Filter') %> <i class="bi bi-chevron-down small ms-1"></i>
                        </button>
                        <div class="btn-group rounded-pill overflow-hidden border">
                            <a href="/periods/manage?groupBy=day" class="btn btn-sm <%= groupBy === 'day' ? 'btn-primary' : 'btn-white text-muted' %> px-3"><%= __('Group_By_Day') %></a>
                            <a href="/periods/manage?groupBy=teacher" class="btn btn-sm <%= groupBy === 'teacher' ? 'btn-primary' : 'btn-white text-muted' %> px-3"><%= __('Group_By_Teacher') %></a>
                        </div>
                    </div>
                </div>
                
                <!-- Expandable Filter Chips -->
                <div class="collapse mt-3" id="filterCollapse">
                    <div class="p-3 bg-light rounded-4 border border-primary-subtle border-dashed">
                        <% if (groupBy !== 'day') { %>
                        <div class="mb-3">
                            <small class="text-muted d-block mb-1 fw-bold"><%= __('Filter_By_Teacher') %></small>
                            <div class="d-flex flex-wrap gap-2" id="teacherFilters">
                                <button class="btn btn-sm btn-dark rounded-pill px-3 filter-chip active" data-filter="all" data-type="teacher"><%= __('All') %></button>
                                <% 
                                    const colors = ['primary', 'success', 'danger', 'warning', 'info', 'indigo', 'orange', 'teal', 'purple'];
                                    const uniqueTeachers = [...new Set(periods.map(p => p.teacher_name))];
                                    uniqueTeachers.forEach((name, i) => { 
                                        const color = colors[i % colors.length];
                                %>
                                    <button class="btn btn-sm btn-outline-<%= color %> rounded-pill px-3 filter-chip" data-filter="<%= name %>" data-type="teacher"><%= name %></button>
                                <% }) %>
                            </div>
                        </div>
                        <% } %>
                        <div>
                            <small class="text-muted d-block mb-1 fw-bold"><%= __('Filter_By_Day') %></small>
                            <div class="d-flex flex-wrap gap-2" id="dayFilters">
                                <button class="btn btn-sm btn-dark rounded-pill px-3 filter-chip active" data-filter="all" data-type="day"><%= __('All') %></button>
                                <% 
                                    const uniqueDays = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
                                    uniqueDays.forEach(day => { 
                                %>
                                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-3 filter-chip" data-filter="<%= day %>" data-type="day"><%= __(day) %></button>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="px-4" style="width: 15%;"><%= __('Period_Label') %></th>
                                <th style="width: 25%;"><%= groupBy === 'teacher' ? __('Day') : __('Filter_By_Teacher').replace(':', '') %></th>
                                <th style="width: 15%;"><%= __('Class') %></th>
                                <th style="width: 30%;"><%= __('Book_Subject') %></th>
                                <th class="px-4 text-center" style="width: 15%;"><%= __('Actions') %></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% 
                                let lastGroup = '';
                                periods.forEach(p => { 
                                    const currentGroup = groupBy === 'teacher' ? p.teacher_name : __(p.day_of_week);
                                    if (currentGroup !== lastGroup) {
                                        lastGroup = currentGroup;
                            %>
                                <tr class="table-secondary group-header" data-group="<%= currentGroup %>">
                                    <td colspan="5" class="px-4 fw-bold text-primary bg-primary-subtle border-0">
                                        <i class="bi <%= groupBy === 'teacher' ? 'bi-person-badge' : 'bi-calendar-event' %> me-2"></i>
                                        <%= currentGroup %>
                                    </td>
                                </tr>
                            <% } %>
                                <tr class="period-row" data-teacher="<%= p.teacher_name %>" data-day="<%= p.day_of_week %>">
                                    <td class="px-4">
                                        <span class="badge bg-secondary-subtle text-secondary border rounded-pill">
                                            <%= __('Period_Label') %> <%= p.period_number || __('Not_Specified') %>
                                        </span>
                                    </td>
                                    <td><%= groupBy === 'teacher' ? __(p.day_of_week) : p.teacher_name %></td>
                                    <td><%= p.class_name %></td>
                                    <td>
                                        <div class="subject-text-wrap fw-bold text-dark"><%= p.book_title || p.subject || __('Not_Specified') %></div>
                                    </td>
                                    <td class="px-4 text-center">
                                        <button class="btn btn-sm btn-outline-primary rounded-circle p-2 lh-1 me-1" 
                                                onclick='openEditModal(<%- JSON.stringify(p) %>)' title="<%= __('Edit') %>">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-circle p-2 lh-1" 
                                                onclick="deletePeriod(<%= p.id %>)" title="<%= __('Delete') %>">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if (periods.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted"><%= __('No_Periods_Registered') %></td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Period Modal -->
<div class="modal fade" id="editPeriodModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title text-white"><%= __('Edit_Period') %></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="editPeriodForm" method="POST">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold"><%= __('Book_Assignment') %></label>
                        <select name="assignmentId" id="editAssignmentId" class="form-select" required>
                            <% assignments.forEach(a => { %>
                                <option value="<%= a.id %>"><%= a.teacher_name %> - <%= a.book_title %> (<%= a.class_name %>)</option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold"><%= __('Day') %></label>
                        <select name="dayOfWeek" id="editDayOfWeek" class="form-select" required>
                            <% dayNames.forEach(day => { %>
                                <option value="<%= day %>"><%= __(day) %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold"><%= __('Period_Number') %></label>
                        <select name="periodNumber" id="editPeriodNumber" class="form-select" onchange="autoFillTimes('edit')" required>
                            <% for(let i=1; i<=7; i++) { %>
                                <option value="<%= i %>"><%= i <= 5 ? __('Period_Label') + ' ' + i : __('Extra_Period') + ' ' + (i - 5) %></option>
                            <% } %>
                        </select>
                    </div>
                    <div class="row d-none">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold"><%= __('Start_Time') %></label>
                            <input type="time" name="startTime" id="editStartTime" class="form-control">
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold"><%= __('End_Time') %></label>
                            <input type="time" name="endTime" id="editEndTime" class="form-control">
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal"><%= __('Cancel') %></button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4"><%= __('Save_Changes') %></button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function openEditModal(period) {
    const modal = new bootstrap.Modal(document.getElementById('editPeriodModal'));
    document.getElementById('editPeriodForm').action = `/periods/edit/${period.id}`;
    document.getElementById('editAssignmentId').value = period.assignment_id || '';
    document.getElementById('editDayOfWeek').value = period.day_of_week || 'Monday';
    document.getElementById('editPeriodNumber').value = period.period_number || 1;
    document.getElementById('editStartTime').value = period.start_time.substring(0,5);
    document.getElementById('editEndTime').value = period.end_time.substring(0,5);
    modal.show();
}

function autoFillTimes(type) {
    const pNum = document.getElementById(type === 'add' ? 'addPeriodNumber' : 'editPeriodNumber').value;
    const startTimeInput = document.getElementById(type === 'add' ? 'addStartTime' : 'editStartTime');
    const endTimeInput = document.getElementById(type === 'add' ? 'addEndTime' : 'editEndTime');

    const times = {
        1: { start: '18:00', end: '18:40' },
        2: { start: '18:40', end: '19:20' },
        3: { start: '19:40', end: '20:20' },
        4: { start: '20:20', end: '21:00' },
        5: { start: '21:00', end: '21:40' }
    };

    if (times[pNum]) {
        startTimeInput.value = times[pNum].start;
        endTimeInput.value = times[pNum].end;
    }
}

// Initial fill for add form
window.addEventListener('DOMContentLoaded', () => {
    if (document.getElementById('addPeriodNumber')) autoFillTimes('add');
});

function updateFieldsFromAssignment() {
    const select = document.getElementById('assignmentSelect');
    const option = select.options[select.selectedIndex];
    if (option.value) {
        document.getElementById('teacherIdInput').value = option.dataset.teacherId;
        document.getElementById('classIdInput').value = option.dataset.classId;
    }
}

async function deletePeriod(id) {
    if (!confirm('<%= __('Confirm_Delete_Period') %>')) return;
    const res = await fetch(`/periods/delete/${id}`, { method: 'POST' });
    if ((await res.json()).success) {
        location.reload();
    } else {
        alert('<%= __('Delete_Error') %>');
    }
}

// Filtering Logic
let activeFilters = { teacher: 'all', day: 'all' };

document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', function() {
        const type = this.dataset.type;
        const filter = this.dataset.filter;
        
        // Update active filters
        activeFilters[type] = filter;
        
        // Update UI state
        document.querySelectorAll(`.filter-chip[data-type="${type}"]`).forEach(c => {
            c.classList.remove('active', 'btn-dark', 'btn-primary', 'btn-success', 'btn-danger', 'btn-warning', 'btn-info', 'btn-secondary');
            // Restore original outline color
            const originalColor = c.getAttribute('class').match(/btn-outline-(\w+)/);
            if (!originalColor) {
                const colorMatch = c.dataset.filter === 'all' ? 'dark' : (c.classList.toString().match(/btn-(\w+)/) || [null, 'secondary'])[1];
                c.classList.add(`btn-outline-${colorMatch}`);
            }
        });
        
        this.classList.add('active');
        const colorMatch = this.classList.toString().match(/btn-outline-(\w+)/);
        const color = colorMatch ? colorMatch[1] : 'dark';
        this.classList.remove(`btn-outline-${color}`);
        this.classList.add(`btn-${color}`);

        applyFilters();
    });
});

function applyFilters() {
    const rows = document.querySelectorAll('.period-row');
    const headers = document.querySelectorAll('.group-header');
    
    rows.forEach(row => {
        const matchTeacher = activeFilters.teacher === 'all' || row.dataset.teacher === activeFilters.teacher;
        const matchDay = activeFilters.day === 'all' || row.dataset.day === activeFilters.day;
        
        if (matchTeacher && matchDay) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });

    // Hide empty group headers
    headers.forEach(header => {
        let next = header.nextElementSibling;
        let hasVisible = false;
        while (next && !next.classList.contains('group-header')) {
            if (next.style.display !== 'none') {
                hasVisible = true;
                break;
            }
            next = next.nextElementSibling;
        }
        header.style.display = hasVisible ? '' : 'none';
    });
}
</script>

<%- include('partials/footer') %>
