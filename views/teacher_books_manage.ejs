<%- include('partials/header') %>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h1 class="fw-bold text-primary mb-0">توزيع الكتب على المعلمين</h1>
        <div class="mt-2">
            <span class="badge bg-success-subtle text-success border rounded-pill px-4 py-2 fs-6">
                <i class="bi bi-calendar-check me-2"></i>الفصل الدراسي الحالي: 1447-1448
            </span>
        </div>
    </div>
    <div class="col-md-6 text-start">
        <a href="/" class="btn btn-outline-primary rounded-pill px-4">
            <i class="bi bi-house-door me-2"></i>الرجوع للوحة التحكم
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-success text-white rounded-top-4 p-3">
                <h5 class="mb-0">إسناد كتاب جديد</h5>
            </div>
            <div class="card-body p-4">
                <form action="/teacher-books/assign" method="POST">
                    <input type="hidden" name="sessionId" value="<%= sessions.find(s => s.is_active).id %>">
                    <div class="mb-3">
                        <label class="form-label fw-bold">المعلم</label>
                        <select name="teacherId" class="form-select" required>
                            <option value="">اختر المعلم...</option>
                            <% teachers.forEach(t => { %>
                                <option value="<%= t.id %>"><%= t.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الكتاب</label>
                        <select name="bookId" class="form-select" required>
                            <option value="">اختر الكتاب...</option>
                            <% books.forEach(b => { %>
                                <option value="<%= b.id %>"><%= b.title %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الصف (Saf)</label>
                        <select name="classId" class="form-select" required>
                            <option value="">اختر الصف...</option>
                            <% classes.forEach(c => { %>
                                <option value="<%= c.id %>"><%= c.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">من صفحة</label>
                            <input type="number" name="startPage" class="form-control" value="1" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">إلى صفحة</label>
                            <input type="number" name="endPage" class="form-control" value="500" required>
                        </div>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-success rounded-pill py-2 fw-bold">إتمام الإسناد</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-journal-text me-2 text-success"></i>قائمة التوزيعات الحالية</h5>
            <button class="btn btn-outline-secondary btn-sm rounded-pill px-3" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse">
                <i class="bi bi-filter me-1"></i>تصفية <i class="bi bi-chevron-down small ms-1"></i>
            </button>
        </div>

        <!-- Expandable Filter Chips Panel -->
        <div class="collapse mb-4" id="filterCollapse">
            <div class="p-3 bg-light rounded-4 border border-success-subtle border-dashed">
                <!-- 1. Filter by Teacher -->
                <div class="mb-3">
                    <small class="text-muted d-block mb-1 fw-bold">تصفية حسب المعلم</small>
                    <div class="d-flex flex-wrap gap-2" id="teacherFilters">
                        <button class="btn btn-sm btn-success rounded-pill px-3 filter-chip active" data-filter="all" data-type="teacher">الكل</button>
                        <% 
                            const teacherColors = ['primary', 'success', 'danger', 'warning', 'info', 'indigo', 'orange', 'teal', 'purple'];
                            const uniqueTeachers = [...new Set(assignments.map(a => a.teacher_name))];
                            uniqueTeachers.forEach((name, i) => { 
                                const color = teacherColors[i % teacherColors.length];
                        %>
                            <button class="btn btn-sm btn-outline-<%= color %> rounded-pill px-3 filter-chip" data-filter="<%= name %>" data-type="teacher"><%= name %></button>
                        <% }) %>
                    </div>
                </div>
                <!-- 2. Filter by Class -->
                <div>
                    <small class="text-muted d-block mb-1 fw-bold">تصفية حسب الصف</small>
                    <div class="d-flex flex-wrap gap-2" id="classFilters">
                        <button class="btn btn-sm btn-success rounded-pill px-3 filter-chip active" data-filter="all" data-type="class">الكل</button>
                        <% 
                            const classColors = ['primary', 'success', 'danger', 'warning', 'info', 'indigo', 'orange', 'teal', 'purple'];
                            const uniqueClasses = [...new Set(assignments.map(a => a.class_name || 'غير محدد'))];
                            uniqueClasses.forEach((name, i) => { 
                                const color = classColors[i % classColors.length];
                        %>
                            <button class="btn btn-sm btn-outline-<%= color %> rounded-pill px-3 filter-chip" data-filter="<%= name %>" data-type="class"><%= name %></button>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>

        <% 
            const grouped = {};
            assignments.forEach(a => {
                if (!grouped[a.teacher_name]) grouped[a.teacher_name] = [];
                grouped[a.teacher_name].push(a);
            });
        %>

        <% Object.keys(grouped).forEach(teacherName => { %>
            <div class="card shadow-sm border-0 rounded-4 mb-4 teacher-assignment-card" data-teacher="<%= teacherName %>">
                <div class="card-header bg-white p-4 border-0">
                    <h5 class="fw-bold mb-0 text-success">
                        <i class="bi bi-person-workspace me-2"></i>المعلم: <%= teacherName %>
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 text-end">
                            <thead class="table-light">
                                <tr>
                                    <th class="px-4">الكتاب</th>
                                    <th>الصف (Saf)</th>
                                    <th>المدى (الصفحات)</th>
                                    <th class="px-4 text-center">الإجراءات</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% grouped[teacherName].forEach(a => { %>
                                    <tr class="assignment-row" data-book-id="<%= a.book_id %>" data-class-id="<%= a.class_id %>" data-class="<%= a.class_name || 'غير محدد' %>">
                                        <td class="px-4">
                                            <div class="fw-bold text-dark"><%= a.book_title %></div>
                                            <% 
                                                const total = a.end_page - a.start_page;
                                                const completed = a.current_page - a.start_page;
                                                const percentage = total > 0 ? Math.min(100, Math.max(0, Math.round((completed / total) * 100))) : 0;
                                            %>
                                            <div class="mt-1 d-flex align-items-center gap-2" style="max-width: 200px;">
                                                <div class="progress flex-grow-1" style="height: 6px; border-radius: 3px; background-color: #e9ecef;">
                                                    <div class="progress-bar bg-success" style="width: <%= percentage %>%"></div>
                                                </div>
                                                <small class="text-muted" style="font-size: 0.7rem; white-space: nowrap;">
                                                    ص <%= a.current_page %> (<%= percentage %>%)
                                                </small>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-primary-subtle text-primary border rounded-pill px-3">
                                                <%= a.class_name || 'غير محدد' %>
                                            </span>
                                        </td>
                                        <td>
                                            <small class="text-muted">من <%= a.start_page %> إلى <%= a.end_page %></small>
                                        </td>
                                        <td class="px-4 text-center">
                                            <button class="btn btn-sm btn-success rounded-pill px-3 ms-1" 
                                                    onclick="openProgressModal(<%= JSON.stringify(a) %>)">
                                                تحديث التقدم
                                            </button>
                                            <button class="btn btn-sm btn-primary rounded-pill px-3 ms-1" 
                                                    onclick="openEditModal(<%= JSON.stringify(a) %>)">
                                                تعديل
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3 ms-1" 
                                                    onclick="deleteAssignment(<%= a.id %>)">
                                                إلغاء
                                            </button>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<!-- Edit Assignment Modal -->
<div class="modal fade" id="editAssignmentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title">تعديل بيانات التوزيع</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="editAssignmentForm">
                    <input type="hidden" id="editAssignmentId">
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">المعلم</label>
                        <select id="editTeacherId" class="form-select" required>
                            <% teachers.forEach(t => { %>
                                <option value="<%= t.id %>"><%= t.name %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">الكتاب</label>
                        <select id="editBookId" class="form-select" required>
                            <% books.forEach(b => { %>
                                <option value="<%= b.id %>"><%= b.title %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">من صفحة</label>
                            <input type="number" id="editStartPage" class="form-control" required>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-bold">إلى صفحة</label>
                            <input type="number" id="editEndPage" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الصف (Saf)</label>
                        <select id="editClassId" class="form-select" required>
                            <% classes.forEach(c => { %>
                                <option value="<%= c.id %>"><%= c.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <input type="hidden" id="editSessionId">
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill py-2">حفظ التغييرات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Update Progress Modal -->
<div class="modal fade" id="updateProgressModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header bg-success text-white rounded-top-4">
                <h5 class="modal-title">تحديث تقدم الكتاب</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="updateProgressForm">
                    <input type="hidden" id="progAssignmentId">
                    <div class="mb-3 text-center">
                        <h6 class="fw-bold text-dark mb-1" id="progBookTitle"></h6>
                        <p class="text-muted small" id="progTeacherName"></p>
                    </div>
                    <div class="mb-4 text-center">
                        <label class="form-label fw-bold d-block mb-3">رقم الصفحة الحالية</label>
                        <div class="d-flex align-items-center justify-content-center gap-3">
                            <input type="number" id="progPageNumber" 
                                   class="form-control border-0 shadow-sm rounded-3 text-center fw-bold text-success bg-light" 
                                   style="height: 60px; font-size: 1.5rem; width: 150px;"
                                   required>
                        </div>
                        <small class="text-muted mt-2 d-block" id="progRangeText"></small>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-success rounded-pill py-2 fw-bold">حفظ التحديث</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
let editModal, progressModal;
document.addEventListener('DOMContentLoaded', () => {
    editModal = new bootstrap.Modal(document.getElementById('editAssignmentModal'));
    progressModal = new bootstrap.Modal(document.getElementById('updateProgressModal'));
});

function openEditModal(a) {
    document.getElementById('editAssignmentId').value = a.id;
    document.getElementById('editTeacherId').value = a.teacher_id;
    document.getElementById('editBookId').value = a.book_id;
    document.getElementById('editStartPage').value = a.start_page;
    document.getElementById('editEndPage').value = a.end_page;
    document.getElementById('editClassId').value = a.class_id;
    document.getElementById('editSessionId').value = a.session_id;
    editModal.show();
}

function openProgressModal(a) {
    document.getElementById('progAssignmentId').value = a.id;
    document.getElementById('progBookTitle').innerText = a.book_title;
    document.getElementById('progTeacherName').innerText = `المعلم: ${a.teacher_name}`;
    document.getElementById('progPageNumber').value = a.current_page;
    document.getElementById('progPageNumber').min = a.start_page;
    document.getElementById('progPageNumber').max = a.end_page;
    document.getElementById('progRangeText').innerText = `النطاق المسموح: من ${a.start_page} إلى ${a.end_page}`;
    progressModal.show();
}

document.getElementById('updateProgressForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const assignmentId = document.getElementById('progAssignmentId').value;
    const pageNumber = document.getElementById('progPageNumber').value;
    
    const res = await fetch('/book/update-progress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ assignmentId, pageNumber })
    });
    const data = await res.json();
    if (data.success) {
        location.reload();
    } else {
        alert('خطأ: ' + (data.error || 'فشل التحديث'));
    }
});

document.getElementById('editAssignmentForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('editAssignmentId').value;
    const teacherId = document.getElementById('editTeacherId').value;
    const bookId = document.getElementById('editBookId').value;
    const startPage = document.getElementById('editStartPage').value;
    const endPage = document.getElementById('editEndPage').value;
    const classId = document.getElementById('editClassId').value;
    const sessionId = document.getElementById('editSessionId').value;

    const res = await fetch(`/teacher-books/edit/${id}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ teacherId, bookId, startPage, endPage, classId, sessionId })
    });
    if ((await res.json()).success) location.reload();
});

async function deleteAssignment(id) {
    try {
        const checkRes = await fetch(`/teacher-books/check-periods/${id}`);
        const checkData = await checkRes.json();
        
        if (checkData.success && checkData.count > 0) {
            const isConfirmed = await showConfirm(`تنبيه: هناك عدد ${checkData.count} حصص مسندة في جدول الحصص لهذا الكتاب/المعلم. سيؤدي إلغاء هذا الإسناد إلى حذف تلك الحصص أيضاً من جدول الحصص نهائياً. هل تريد الاستمرار في الحذف؟`);
            if (!isConfirmed) return;
        } else {
            const isConfirmed = await showConfirm('هل أنت متأكد من إلغاء هذا الإسناد؟');
            if (!isConfirmed) return;
        }
        
        const res = await fetch(`/teacher-books/delete/${id}`, { method: 'POST' });
        if ((await res.json()).success) location.reload();
    } catch (err) {
        console.error(err);
        alert('حدث خطأ أثناء محاولة الحذف.');
    }
}

// Filtering Logic
let activeFilters = { teacher: 'all', class: 'all' };

const storedFilters = localStorage.getItem('activeFilters_teacher_books');
if (storedFilters) {
    try {
        activeFilters = JSON.parse(storedFilters);
    } catch (e) {
        console.error(e);
    }
}

function updateChipsUI(type, filter) {
    const chips = document.querySelectorAll(`.filter-chip[data-type="${type}"]`);
    chips.forEach(c => {
        c.classList.remove('active', 'btn-dark', 'btn-primary', 'btn-success', 'btn-danger', 'btn-warning', 'btn-info', 'btn-secondary');
        // Restore original outline color
        const originalColor = c.getAttribute('class').match(/btn-outline-(\w+)/);
        if (!originalColor) {
            const colorMatch = c.dataset.filter === 'all' ? 'success' : (c.classList.toString().match(/btn-(\w+)/) || [null, 'secondary'])[1];
            c.classList.add(`btn-outline-${colorMatch}`);
        }
    });
    
    const activeChip = Array.from(chips).find(c => c.dataset.filter === filter);
    if (activeChip) {
        activeChip.classList.add('active');
        const colorMatch = activeChip.classList.toString().match(/btn-outline-(\w+)/);
        const color = colorMatch ? colorMatch[1] : 'success';
        activeChip.classList.remove(`btn-outline-${color}`);
        activeChip.classList.add(`btn-${color}`);
    }
}

document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', function() {
        const type = this.dataset.type;
        const filter = this.dataset.filter;
        
        activeFilters[type] = filter;
        localStorage.setItem('activeFilters_teacher_books', JSON.stringify(activeFilters));
        
        updateChipsUI(type, filter);
        applyFilters();
    });
});

function applyFilters() {
    const cards = document.querySelectorAll('.teacher-assignment-card');
    cards.forEach(card => {
        const cardTeacher = card.getAttribute('data-teacher');
        const rows = card.querySelectorAll('.assignment-row');
        let visibleRowsCount = 0;

        const matchTeacher = activeFilters.teacher === 'all' || cardTeacher === activeFilters.teacher;

        rows.forEach(row => {
            const rowClass = row.getAttribute('data-class');
            const matchClass = activeFilters.class === 'all' || rowClass === activeFilters.class;

            if (matchTeacher && matchClass) {
                row.style.setProperty('display', '', 'important');
                visibleRowsCount++;
            } else {
                row.style.setProperty('display', 'none', 'important');
            }
        });

        // Show card only if teacher matches and we have visible rows
        if (matchTeacher && visibleRowsCount > 0) {
            card.style.setProperty('display', '', 'important');
        } else {
            card.style.setProperty('display', 'none', 'important');
        }
    });
}

// Restore saved filters on load
document.addEventListener('DOMContentLoaded', () => {
    Object.keys(activeFilters).forEach(type => {
        updateChipsUI(type, activeFilters[type]);
    });
    
    const hasActiveFilter = Object.values(activeFilters).some(v => v !== 'all');
    if (hasActiveFilter) {
        const collapseEl = document.getElementById('filterCollapse');
        if (collapseEl) {
            collapseEl.classList.add('show');
        }
    }
    
    applyFilters();
});
</script>

<%- include('partials/footer') %>
